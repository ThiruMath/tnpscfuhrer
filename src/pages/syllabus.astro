            { num: "III", title: "Writing Skills", questions: 10, tags: ["letter writing", "english writing"], topics: ["Letter writing (formal and informal)", "Jumbled sentences, Finding right order", "Inferences, Blanks, Substitutions"] },
            { num: "IV", title: "Technical Terms", questions: 10, tags: ["administrative terms", "technical english"], topics: ["Administrative Terms, Department related", "General and Official terms", "Official Correspondence (basics)"] },
            { num: "V", title: "Reading Comprehension", questions: 20, tags: ["comprehension", "reading"], topics: ["Unseen passages – Newspaper, Headlines, Editorials", "Government related News", "Strong question, Weak question, Match the following", "Sentence Completion, Ascertainment of facts"] },
            { num: "VI", title: "Translation", questions: 5, tags: ["translation", "tense voice"], topics: ["Word Translation, Sentence Translation", "Tense related translation tasks", "Tense / Voice related tasks"] },
            { num: "VII", title: "Literary Works (SSLC Standard)", questions: 15, tags: ["poetry", "prose", "literature", "robert frost"], topics: ["Figures of Speech, Appreciation and Analysis of Poetry", "Poems: I Dream of Spices, The Crocodile, Sea Fever, Stopping by Woods on a Snowy Evening, A Poison Tree, The Secret of the Machines", "Prose: His First Flight, The Last Lesson, The Dying Detective, Learning The Game, Water – The Elixir of Life", "Biography of Srinivasa Ramanujan, A Birthday Letter by Nehru"] }
          ]
        }
      ]
    }
  ]
};

// Build related notes for each unit
for (const part of syllabus.parts) {
  if (part.units) {
    for (const unit of part.units as any[]) {
      unit.relatedNotes = findRelatedNotes(unit.tags);
    }
  }
  if (part.sections) {
    for (const section of part.sections as any[]) {
      for (const unit of section.units as any[]) {
        unit.relatedNotes = findRelatedNotes(unit.tags);
      }
    }
  }
}
---

<Layout title="TNPSC Group II/IIA Syllabus – Code 495" description="Complete structured TNPSC Group II and Group IIA Preliminary Exam Syllabus (Code 495) with unit-wise breakdown and linked study notes." active="TNPSC">
  <main>
    <!-- Hero Banner -->
    <div class="syllabus-hero">
      <div class="container">
        <div class="hero-badge">
