          </div>
          <div class="meta-chip">
            <span class="chip-icon">🗣️</span>
            <div>
              <div class="chip-label">Part C</div>
              <div class="chip-val">Language – 100 Qs</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="container syllabus-body">
      <!-- Filter bar -->
      <div class="filter-bar">
        <span class="filter-label">Jump to:</span>
        <a href="#partA" class="filter-btn active">Part A – General Studies</a>
        <a href="#partB" class="filter-btn">Part B – Aptitude</a>
        <a href="#partC" class="filter-btn">Part C – Language</a>
      </div>

      <!-- PART A -->
      <section id="partA" class="part-section">
        <div class="part-header" style="--part-color: #C1121F">
          <span class="part-icon">📘</span>
          <div>
            <h2>Part A – General Studies</h2>
            <p>Degree Standard · 75 Questions</p>
          </div>
          <div class="part-qs-badge">75 Qs</div>
        </div>

        <div class="units-grid">
          {syllabus.parts[0].units?.map((unit: any) => (
            <div class="unit-card" data-part="A">
