                  <div class="unit-num" style="--uc:#be185d">Unit {unit.num}</div>
                  <div class="unit-qs">{unit.questions} Questions</div>
                </div>
                <h3 class="unit-title">{unit.title}</h3>
                <ul class="topic-list">
                  {unit.topics.map((t: string) => (
                    <li><span class="bullet" style="--bc:#be185d"></span>{t}</li>
                  ))}
                </ul>
                {unit.relatedNotes.length > 0 && (
                  <div class="related-notes">
                    <div class="notes-label">📝 Related Notes</div>
                    <div class="notes-chips">
                      {unit.relatedNotes.map((n: any) => (
                        <a href={`/notes/${n.slug}`} class="note-chip note-chip--pink">
                          {n.title.length > 28 ? n.title.slice(0, 28) + '…' : n.title}
