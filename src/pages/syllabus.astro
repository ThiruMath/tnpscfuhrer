---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');

// Tag → note slug mapping function
function findRelatedNotes(keywords: string[]) {
  return allNotes
    .filter(note => {
      const titleLower = note.slug.toLowerCase().replace(/-/g, ' ');
      const bodyLower = (note.body || '').toLowerCase().slice(0, 500);
      return keywords.some(kw => titleLower.includes(kw) || bodyLower.includes(kw));
    })
    .slice(0, 4)
    .map(n => ({ title: n.data.title || n.slug.replace(/-/g, ' '), slug: n.slug }));
}

// Syllabus Data
const syllabus = {
  exam: "Combined Civil Services Examination – II",
  groups: "Group II & IIA Services",
  code: "495",
  date: "12.12.2024",
  parts: [
    {
