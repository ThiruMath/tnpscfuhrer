            { num: "III", title: "எழுதும் திறன் / Writing Skills", questions: 15, tags: ["tamil writing", "thodarchollu"], topics: ["சொற்களை ஒழுங்குபடுத்துதல்", "மரபுத்தமிழ் – திணை, பால், காலம் மரபு", "நிறுத்தல் குறியீடுகள்"] },
            { num: "IV", title: "கலைச் சொற்கள் / Technical Terms", questions: 10, tags: ["tamil technical terms", "kalai sol"], topics: ["அறிவியல், கல்வி, மருத்துவம் – கலைச்சொற்கள்", "Search engine – தேடு பொறி", "Gene – மரபணு, Allergy – ஒவ்வாமை"] },
