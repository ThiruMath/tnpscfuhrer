---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="About | TNPSC Fuhrer"
  description="Learn about TNPSC Fuhrer — a free exam preparation platform for Tamil Nadu Public Service Commission aspirants."
>
  <main class="about-page">
    <section class="hero">
      <h1>About TNPSC Fuhrer</h1>
      <p class="tagline">Your free, open platform for TNPSC exam preparation.</p>
    </section>

    <section class="content">
      <p>
        TNPSC Fuhrer is built for aspirants preparing for Tamil Nadu Public 
        Service Commission examinations — offering organized, concise, and 
        easy-to-revise study material.
      </p>

      <h2>What We Cover</h2>
      <ul>
        <li>General Studies &amp; Current Affairs</li>
        <li>Tamil Language &amp; Literature</li>
        <li>History, Polity &amp; Geography</li>
        <li>Economics &amp; Science</li>
        <li>Group 2, 2A, 4 &amp; VAO Preparation</li>
      </ul>

      <h2>Our Goal</h2>
      <p>
        To make quality TNPSC study material accessible to everyone — free, 
        fast, and always up to date.
      </p>

      <h2>Contribute</h2>
      <p>
        Found an error or want to contribute notes? Visit us on 
        <a href="https://github.com/ThiruMath/tnpscfuhrer" target="_blank">GitHub</a>.
      </p>
    </section>
  </main>
</Layout>

<style>
  .about-page {
    max-width: 800px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  .hero {
    margin-bottom: 2rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .tagline {
    font-size: 1.2rem;
    opacity: 0.7;
  }

  h2 {
    font-size: 1.5rem;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  ul {
    padding-left: 1.5rem;
    line-height: 2;
  }

  a {
    color: inherit;
    text-decoration: underline;
  }
</style>