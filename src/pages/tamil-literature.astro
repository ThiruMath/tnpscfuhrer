---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Home">

<!-- ═══ HERO ═══ -->
<section class="hero">
  <div class="hero-bg">
    <div class="hero-orb hero-orb--1"></div>
    <div class="hero-orb hero-orb--2"></div>
    <svg class="hero-mandala" viewBox="0 0 600 600" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
      <g transform="translate(300,300)">
        <circle r="280" fill="none" stroke="rgba(201,152,58,0.06)" stroke-width="1"/>
        <circle r="230" fill="none" stroke="rgba(201,152,58,0.08)" stroke-width="0.5"/>
        <circle r="180" fill="none" stroke="rgba(201,152,58,0.1)" stroke-width="1"/>
        <circle r="130" fill="none" stroke="rgba(201,152,58,0.12)" stroke-width="0.5"/>
        <circle r="80"  fill="none" stroke="rgba(201,152,58,0.15)" stroke-width="1"/>
        <!-- petals -->
        {Array.from({length:24}).map((_,i) => (
          <line
            x1="0" y1="85" x2="0" y2="275"
            stroke={`rgba(201,152,58,${0.03 + (i%3)*0.02})`}
            stroke-width="0.5"
            transform={`rotate(${i*15})`}
          />
        ))}
        {Array.from({length:8}).map((_,i) => (
          <ellipse cx="0" cy="155" rx="12" ry="40"
            fill="none"
            stroke="rgba(201,152,58,0.12)"
            stroke-width="0.5"
            transform={`rotate(${i*45})`}
          />
        ))}
        <circle r="12" fill="none" stroke="rgba(201,152,58,0.25)" stroke-width="1"/>
        <circle r="4"  fill="rgba(201,152,58,0.3)"/>
      </g>
    </svg>
    <div class="hero-grain"></div>
  </div>

  <div class="hero-content">
    <p class="hero-eyebrow animate-fadeup" style="animation-delay:0.1s">
      <span>✦</span> Over 2,000 Years of Literary Heritage <span>✦</span>
    </p>
    <h1 class="hero-title animate-fadeup" style="animation-delay:0.2s">
      <span class="hero-title-tamil">தமிழ்</span>
      <span class="hero-title-english">Literature</span>
    </h1>
    <p class="hero-subtitle animate-fadeup" style="animation-delay:0.35s">
      The oldest classical literature tradition still spoken today — <br/>
      from Sangam love poems to Thirukkural's timeless wisdom.
    </p>
    <div class="hero-cta animate-fadeup" style="animation-delay:0.5s">
      <a href="/sangam" class="btn btn--primary">Begin the Journey</a>
      <a href="/kurals" class="btn btn--ghost">Read Thirukkural</a>
    </div>
    <div class="hero-stat-row animate-fadeup" style="animation-delay:0.65s">
      <div class="hero-stat">
        <span class="hero-stat-num">2,000+</span>
        <span class="hero-stat-label">Years of Literature</span>
      </div>
      <div class="hero-stat-sep"></div>
      <div class="hero-stat">
        <span class="hero-stat-num">1,330</span>
        <span class="hero-stat-label">Kural couplets</span>
      </div>
      <div class="hero-stat-sep"></div>
      <div class="hero-stat">
        <span class="hero-stat-num">473</span>
        <span class="hero-stat-label">Sangam poems preserved</span>
      </div>
    </div>
  </div>

  <div class="hero-scroll">
    <span>Scroll</span>
    <div class="hero-scroll-line"></div>
  </div>
</section>

<!-- ═══ FLOATING SCRIPT SECTION ═══ -->
<section class="script-showcase">
  <div class="container">
    <p class="section-label">The Living Script</p>
    <div class="script-grid">
      {[
        { tamil: 'அ', roman: 'a', meaning: 'The First Letter' },
        { tamil: 'அகம்', roman: 'akam', meaning: 'Interior / Love' },
        { tamil: 'புறம்', roman: 'puram', meaning: 'Exterior / War' },
        { tamil: 'கவிதை', roman: 'kavithai', meaning: 'Poetry' },
        { tamil: 'இலக்கியம்', roman: 'ilakkiyam', meaning: 'Literature' },
        { tamil: 'அன்பு', roman: 'anbu', meaning: 'Love' },
        { tamil: 'வாழ்க்கை', roman: 'vāḻkkai', meaning: 'Life' },
        { tamil: 'ஒளி', roman: 'oḷi', meaning: 'Light' },
      ].map((item, i) => (
        <div class="script-card" style={`animation-delay: ${i * 0.07}s`}>
          <span class="script-char">{item.tamil}</span>
          <span class="script-roman">{item.roman}</span>
          <span class="script-meaning">{item.meaning}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ FEATURED ERAS TIMELINE ═══ -->
<section class="timeline-section">
  <div class="container">
    <p class="section-label">Through the Ages</p>
    <h2 class="section-title">A Timeline of Tamil Literature</h2>
    <p class="section-desc">From the earliest Sangam anthologies to the devotional hymns of the Bhakti era — a literary tradition with no interruption.</p>

    <div class="timeline">
      {[
        {
          era: '300 BCE – 300 CE',
          name: 'Sangam Age',
          tamil: 'சங்க காலம்',
          desc: 'The golden age of Tamil poetry. Love, war, and nature described in vivid, emotional verse by hundreds of named poets.',
          color: '#C9983A',
          href: '/sangam',
          works: ['Akananuru', 'Purananuru', 'Natrinai', 'Kurunthokai'],
        },
        {
          era: '200 CE – 600 CE',
          name: 'Post-Sangam Period',
          tamil: 'பிற்சங்க காலம்',
          desc: 'The era of great epics and didactic literature. Thirukkural, Silappadikaram, and Manimekalai emerge as eternal masterpieces.',
          color: '#8B1A1A',
          href: '/epics',
          works: ['Thirukkural', 'Silappadikaram', 'Manimekalai'],
        },
        {
          era: '600 CE – 900 CE',
          name: 'Bhakti Era',
          tamil: 'பக்தி காலம்',
          desc: 'Nayanmars and Alvars compose devotional hymns of extraordinary beauty. The Thevarams and Divya Prabandhams still ring in temples.',
          color: '#5C6B3A',
          href: '/poets',
          works: ['Tevaram', 'Thiruvasagam', 'Nalayira Divya Prabandham'],
        },
        {
          era: '900 CE – 1200 CE',
          name: 'Medieval Period',
          tamil: 'இடைக்கால காலம்',
          desc: 'The Chola empire patronises literature. Kamban\'s Ramavataram reimagines the Ramayana in a distinctly Tamil voice.',
          color: '#3A5B6B',
          href: '/poets',
          works: ['Kambaramayanam', 'Periyapuranam'],
        },
      ].map((era, i) => (
        <div class="timeline-item" style={`--accent: ${era.color}; animation-delay: ${i * 0.15}s`}>
          <div class="timeline-marker">
            <div class="timeline-dot"></div>
            <div class="timeline-line"></div>
          </div>
          <div class="timeline-body">
            <span class="timeline-era">{era.era}</span>
            <h3 class="timeline-name">{era.name}</h3>
            <p class="timeline-name-tamil">{era.tamil}</p>
            <p class="timeline-desc">{era.desc}</p>
            <div class="timeline-works">
              {era.works.map(w => (
                <span class="timeline-tag">{w}</span>
              ))}
            </div>
            <a href={era.href} class="timeline-link">Explore this era →</a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ═══ KURAL SPOTLIGHT ═══ -->
<section class="kural-spotlight">
  <div class="kural-bg"></div>
  <div class="container kural-inner">
    <p class="section-label" style="color: rgba(201,152,58,0.7)">Thirukkural</p>
    <h2 class="kural-heading">The Universal Wisdom</h2>
    <div class="kural-verse">
      <p class="kural-tamil">அகர முதல எழுத்தெல்லாம் ஆதி<br/>பகவன் முதற்றே உலகு.</p>
      <p class="kural-translation">"As 'A' is the first of all letters,<br/>so is the Eternal the first in the world."</p>
      <p class="kural-meta">— Kural 1, Thiruvalluvar</p>
    </div>
    <a href="/kurals" class="btn btn--gold">Read All 1,330 Kurals</a>
  </div>
</section>

<!-- ═══ FEATURED POETS ═══ -->
<section class="poets-preview">
  <div class="container">
    <p class="section-label">Voices Through Time</p>
    <h2 class="section-title">The Great Poets</h2>
    <div class="poets-grid">
      {[
        { name: 'Thiruvalluvar', tamil: 'திருவள்ளுவர்', period: '~300 BCE', known: 'Thirukkural', icon: '✦' },
        { name: 'Ilango Adigal', tamil: 'இளங்கோ அடிகள்', period: '~2nd century CE', known: 'Silappadikaram', icon: '◆' },
        { name: 'Avvaiyar', tamil: 'ஔவையார்', period: 'Sangam era', known: 'Wisdom poems & Purananuru', icon: '❋' },
        { name: 'Kambar', tamil: 'கம்பர்', period: '12th century CE', known: 'Kambaramayanam', icon: '◇' },
        { name: 'Manikkavacakar', tamil: 'மாணிக்கவாசகர்', period: '9th century CE', known: 'Thiruvasagam', icon: '✿' },
        { name: 'Nammalvar', tamil: 'நம்மாழ்வார்', period: '9th century CE', known: 'Thiruvaymoli', icon: '❖' },
      ].map(poet => (
        <a href="/poets" class="poet-card">
          <div class="poet-icon">{poet.icon}</div>
          <h3 class="poet-name">{poet.name}</h3>
          <p class="poet-tamil">{poet.tamil}</p>
          <p class="poet-period">{poet.period}</p>
          <p class="poet-known">{poet.known}</p>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ═══ CALL TO ACTION ═══ -->
<section class="cta-section">
  <div class="container">
    <div class="cta-inner">
      <h2 class="cta-title">Dive into Two Millennia of Words</h2>
      <p class="cta-body">The Tamil language has never ceased to be spoken, written, and sung. Explore a living tradition from its ancient roots to its modern flowering.</p>
      <div class="cta-buttons">
        <a href="/sangam" class="btn btn--primary">Start with Sangam</a>
        <a href="/epics" class="btn btn--ghost">Discover the Epics</a>
      </div>
    </div>
  </div>
</section>

</Layout>

<style>
/* ─── HERO ─── */
.hero {
  position: relative;
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  padding: 8rem 2rem 5rem;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(92,15,15,0.35) 0%, rgba(15,10,6,0.0) 70%),
              radial-gradient(ellipse 60% 80% at 20% 80%, rgba(201,152,58,0.08) 0%, transparent 60%);
}

.hero-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
  pointer-events: none;
}

.hero-orb--1 {
  width: 600px; height: 600px;
  top: -100px; left: -100px;
  background: radial-gradient(circle, rgba(139,26,26,0.2) 0%, transparent 70%);
  animation: float 8s ease-in-out infinite;
}

.hero-orb--2 {
  width: 500px; height: 500px;
  bottom: -100px; right: -100px;
  background: radial-gradient(circle, rgba(201,152,58,0.12) 0%, transparent 70%);
  animation: float 10s ease-in-out infinite reverse;
}

.hero-mandala {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  width: 80vmin; height: 80vmin;
  opacity: 0.6;
  animation: rotate-slow 120s linear infinite;
  pointer-events: none;
}

.hero-grain {
  position: absolute;
  inset: 0;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
  background-size: 200px 200px;
  opacity: 0.4;
  pointer-events: none;
}

.hero-content {
  position: relative;
  z-index: 2;
  text-align: center;
  max-width: 900px;
}

.hero-eyebrow {
  font-family: var(--font-display);
  font-size: 0.85rem;
  letter-spacing: 0.25em;
  color: var(--gold);
  text-transform: uppercase;
  margin-bottom: 2rem;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
}

.hero-title {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 1.5rem;
}

.hero-title-tamil {
  font-family: var(--font-tamil);
  font-size: clamp(4rem, 14vw, 9rem);
  font-weight: 300;
  color: var(--gold-light);
  line-height: 1;
  letter-spacing: -0.02em;
  background: linear-gradient(135deg, var(--gold-light) 0%, var(--gold) 50%, var(--crimson-light) 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.hero-title-english {
  font-family: var(--font-display);
  font-size: clamp(1.5rem, 5vw, 3.5rem);
  font-weight: 300;
  color: var(--parchment-dark);
  letter-spacing: 0.3em;
  text-transform: uppercase;
  margin-top: 0.25rem;
}

.hero-subtitle {
  font-family: var(--font-body);
  font-size: clamp(1rem, 2.5vw, 1.3rem);
  font-style: italic;
  color: var(--text-muted);
  margin-bottom: 2.5rem;
  line-height: 1.7;
}

.hero-cta {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
  margin-bottom: 4rem;
}

.btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-decoration: none;
  padding: 0.85rem 2.25rem;
  border: 1px solid;
  border-radius: 1px;
  transition: all 0.3s var(--ease-out);
  cursor: pointer;
}

.btn--primary {
  background: var(--crimson);
  border-color: var(--crimson);
  color: var(--parchment);
}
.btn--primary:hover {
  background: var(--crimson-light);
  border-color: var(--crimson-light);
  transform: translateY(-2px);
}

.btn--ghost {
  background: transparent;
  border-color: rgba(201,152,58,0.4);
  color: var(--gold-light);
}
.btn--ghost:hover {
  background: rgba(201,152,58,0.08);
  border-color: var(--gold);
  transform: translateY(-2px);
}

.btn--gold {
  background: transparent;
  border-color: var(--gold);
  color: var(--gold);
}
.btn--gold:hover {
  background: var(--gold);
  color: var(--ink);
  transform: translateY(-2px);
}

.hero-stat-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 2.5rem;
}

.hero-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.hero-stat-num {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 600;
  color: var(--gold-light);
}

.hero-stat-label {
  font-family: var(--font-body);
  font-size: 0.8rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-faint);
}

.hero-stat-sep {
  width: 1px; height: 3rem;
  background: linear-gradient(to bottom, transparent, rgba(201,152,58,0.3), transparent);
}

.hero-scroll {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 0.5rem;
  color: var(--text-faint);
  font-family: var(--font-display);
  font-size: 0.7rem;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  animation: fadeIn 2s ease 1s both;
}

.hero-scroll-line {
  width: 1px; height: 40px;
  background: linear-gradient(to bottom, rgba(201,152,58,0.5), transparent);
  animation: float 2s ease-in-out infinite;
}

/* ─── SCRIPT SHOWCASE ─── */
.script-showcase {
  padding: 6rem 0;
  background: var(--ink-mid);
  border-top: 1px solid rgba(201,152,58,0.1);
  border-bottom: 1px solid rgba(201,152,58,0.1);
}

.script-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(130px, 1fr));
  gap: 1px;
  margin-top: 2rem;
  border: 1px solid rgba(201,152,58,0.1);
}

.script-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 2rem 1rem;
  background: rgba(15,10,6,0.5);
  transition: background 0.3s;
  animation: fadeUp 0.8s var(--ease-out) both;
}

.script-card:hover { background: rgba(139,26,26,0.15); }

.script-char {
  font-family: var(--font-tamil);
  font-size: 2.5rem;
  color: var(--gold-light);
  margin-bottom: 0.5rem;
}

.script-roman {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 0.9rem;
  color: var(--text-muted);
  margin-bottom: 0.25rem;
}

.script-meaning {
  font-family: var(--font-body);
  font-size: 0.75rem;
  letter-spacing: 0.05em;
  color: var(--text-faint);
  text-align: center;
}

/* ─── TIMELINE ─── */
.timeline-section {
  padding: 8rem 0;
}

.section-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 400;
  color: var(--parchment);
  margin-bottom: 1rem;
  line-height: 1.2;
}

.section-desc {
  font-family: var(--font-body);
  font-size: 1.1rem;
  font-style: italic;
  color: var(--text-muted);
  max-width: 60ch;
  margin-bottom: 4rem;
}

.timeline {
  position: relative;
  padding-left: 3rem;
}

.timeline::before {
  content: '';
  position: absolute;
  left: 0.5rem; top: 0; bottom: 0;
  width: 1px;
  background: linear-gradient(to bottom,
    transparent,
    rgba(201,152,58,0.3) 10%,
    rgba(201,152,58,0.3) 90%,
    transparent
  );
}

.timeline-item {
  display: grid;
  grid-template-columns: 40px 1fr;
  gap: 2rem;
  margin-bottom: 4rem;
  animation: fadeUp 0.8s var(--ease-out) both;
}

.timeline-marker {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 0.4rem;
}

.timeline-dot {
  width: 12px; height: 12px;
  border-radius: 50%;
  background: var(--accent, var(--gold));
  border: 2px solid var(--ink);
  box-shadow: 0 0 0 3px rgba(201,152,58,0.15);
  flex-shrink: 0;
  margin-left: -2.75rem;
}

.timeline-body {
  padding-bottom: 3rem;
  border-bottom: 1px solid rgba(201,152,58,0.08);
}

.timeline-item:last-child .timeline-body { border-bottom: none; }

.timeline-era {
  font-family: var(--font-display);
  font-size: 0.8rem;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: var(--accent, var(--gold));
  display: block;
  margin-bottom: 0.5rem;
}

.timeline-name {
  font-family: var(--font-display);
  font-size: 1.8rem;
  font-weight: 500;
  color: var(--parchment);
  margin-bottom: 0.25rem;
}

.timeline-name-tamil {
  font-family: var(--font-tamil);
  font-size: 1rem;
  color: var(--text-muted);
  margin-bottom: 1rem;
}

.timeline-desc {
  font-family: var(--font-body);
  font-size: 1.05rem;
  color: var(--parchment-dark);
  max-width: 65ch;
  margin-bottom: 1.5rem;
  line-height: 1.75;
}

.timeline-works {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin-bottom: 1.5rem;
}

.timeline-tag {
  font-family: var(--font-display);
  font-size: 0.8rem;
  letter-spacing: 0.08em;
  color: var(--accent, var(--gold));
  border: 1px solid rgba(201,152,58,0.25);
  padding: 0.2rem 0.75rem;
  border-radius: 1px;
}

.timeline-link {
  font-family: var(--font-display);
  font-size: 0.9rem;
  letter-spacing: 0.08em;
  color: var(--text-muted);
  text-decoration: none;
  transition: color 0.25s;
}
.timeline-link:hover { color: var(--gold); }

/* ─── KURAL SPOTLIGHT ─── */
.kural-spotlight {
  position: relative;
  padding: 8rem 0;
  overflow: hidden;
}

.kural-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(ellipse 120% 80% at 50% 50%, rgba(92,15,15,0.6) 0%, rgba(15,10,6,0.95) 70%);
}

.kural-inner {
  position: relative;
  z-index: 1;
  text-align: center;
}

.kural-heading {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 300;
  color: var(--parchment);
  margin-bottom: 3rem;
  letter-spacing: 0.05em;
}

.kural-verse {
  max-width: 640px;
  margin: 0 auto 3rem;
  padding: 3rem;
  border: 1px solid rgba(201,152,58,0.2);
  position: relative;
}

.kural-verse::before,
.kural-verse::after {
  content: '';
  position: absolute;
  width: 20px; height: 20px;
  border-color: var(--gold);
  border-style: solid;
  opacity: 0.4;
}
.kural-verse::before { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
