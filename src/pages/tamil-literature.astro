---
import Layout from '../layouts/Layout.astro';

const eras = [
  {
    id: "sangam",
    name: "Sangam Age",
    period: "300 BCE – 300 CE",
    desc: "The golden era of Tamil literature featuring Ettuthogai, Pathupattu, and the foundational grammar Tolkappiyam.",
    color: "#be185d",
    features: ["Ettuthogai (8 Anthologies)", "Pathupattu (10 Idylls)", "Tolkappiyam (Grammar)"],
    icon: "📜"
  },
  {
    id: "post-sangam",
    name: "Post-Sangam Period",
    period: "300 CE – 600 CE",
    desc: "Focus shifted towards ethics and morality, giving birth to Pathinenkilkanakku and the legendary Thirukkural.",
    color: "#0369a1",
    features: ["Thirukkural", "Naladiyar", "Silappatikaram & Manimekalai"],
    icon: "⚖️"
  },
  {
    id: "bhakti",
    name: "Bhakti Literature",
    period: "600 CE – 900 CE",
    desc: "A spiritual renaissance led by the Alwars (Vaishnavism) and Nayanmars (Shaivism) through soul-stirring hymns.",
    color: "#d97706",
    features: ["Tevaram", "Naalayira Divya Prabandham", "Thiruvasagam"],
    icon: "🛕"
  },
  {
    id: "medieval",
    name: "Medieval Epic Era",
    period: "900 CE – 1300 CE",
    desc: "The Imperial Cholas fostered grand epics and puranas, including Kamban's Ramayanam.",
    color: "#0a6e4f",
    features: ["Kamba Ramayanam", "Periya Puranam", "Sivakasinthamani"],
    icon: "👑"
  },
  {
    id: "nayak",
    name: "Nayak Period",
    period: "1300 CE – 1700 CE",
    desc: "Rise of 'Sithrilakkiyam' (Minor Literature) forms like Pillai Tamil, Ula, and Parani.",
    color: "#7c3aed",
    features: ["Pillai Tamil", "Kalingattuparani", "Kuravanji"],
    icon: "🎭"
  },
  {
    id: "modern",
    name: "Modern Literature",
    period: "18th Century – Present",
    desc: "The emergence of novels, short stories, and free verse influenced by Western education and freedom struggle.",
    color: "#c1121f",
    features: ["Bharathiyar & Bharathidasan", "Puthumaippithan", "Kalki's Historical Novels"],
    icon: "📖"
  }
];

const highlights = [
  { value: "5", label: "Great Epics", desc: "Aimperum Kappiyangal" },
  { value: "18", label: "Minor Works", desc: "Pathinenkilkanakku" },
  { value: "12", label: "Alwars", desc: "Vaishnavite Saints" },
  { value: "63", label: "Nayanmars", desc: "Shaivite Saints" }
];
---

<Layout title="Tamil Literature History – TNPSC Unit 8" description="Complete study material for TNPSC Unit 8: History of Tamil Literature from Sangam Age to Modern Era." active="Topics">
  <main>
    <!-- Hero Section -->
    <section class="lit-hero">
      <div class="lit-hero-bg"></div>
      <div class="container hero-content">
        <div class="badge">TNPSC Unit 8 Mastery</div>
        <h1>History of <span class="text-gradient">Tamil Literature</span></h1>
        <p class="subtitle">A comprehensive timeline covering the evolution of one of the world's oldest surviving classical languages, from the ancient Sangam academies to the modern digital era.</p>
        
        <div class="stats-grid">
          {highlights.map(stat => (
            <div class="stat-card">
              <span class="stat-value">{stat.value}</span>
              <div class="stat-info">
                <span class="stat-label">{stat.label}</span>
                <span class="stat-desc">{stat.desc}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <div class="container main-content">
      <!-- Intro Section -->
      <section class="intro-section">
        <div class="intro-text">
          <h2>Why Study Tamil Literature?</h2>
          <p>For TNPSC aspirants, Tamil Literature isn't just a subject; it's the core of <strong>Unit 8 (History, Culture, Heritage, and Socio-Political Movements in Tamil Nadu)</strong>. A deep understanding of literary history helps you trace the socio-political evolution of the Tamil landscape, unlocking critical marks in Group 1, 2, and 4 examinations.</p>
        </div>
        <div class="intro-highlight">
          <div class="kural-box">
            <p class="kural-tamil">"எண்ணென்ப ஏனை எழுத்தென்ப இவ்விரண்டும்<br/>கண்ணென்ப வாழும் உயிர்க்கு."</p>
            <p class="kural-en">— Thirukkural (392)</p>
            <p class="kural-meaning">Numbers and letters, they are known as<br/>eyes to living beings.</p>
          </div>
        </div>
      </section>

      <!-- Timeline Section -->
      <section class="timeline-section">
        <div class="section-header">
          <h2>The Literary Timeline</h2>
          <p>Explore the chronologies of Tamil literary eras and their defining works.</p>
        </div>

        <div class="timeline">
          {eras.map((era, index) => (
            <div class="timeline-item" style={`--era-color: ${era.color}`}>
              <div class="timeline-marker"></div>
              <div class="timeline-content">
                <div class="era-header">
                  <span class="era-icon">{era.icon}</span>
                  <div class="era-titles">
                    <h3>{era.name}</h3>
                    <span class="era-period">{era.period}</span>
                  </div>
                </div>
                <p class="era-desc">{era.desc}</p>
                <div class="era-features">
                  <h4>Key Works / Features:</h4>
                  <ul>
                    {era.features.map(f => (
                      <li>{f}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- Exam Focus -->
      <section class="exam-focus-section">
        <h2>TNPSC Exam Focus Areas</h2>
        <div class="focus-grid">
          <div class="focus-card">
            <div class="focus-icon">📚</div>
            <h3>Samacheer Textbooks</h3>
            <p>The 6th to 12th standard Tamil textbooks are the Bible for this topic. Pay special attention to the "Nool Veli" (author notes) at the end of every poem.</p>
          </div>
          <div class="focus-card">
            <div class="focus-icon">🧠</div>
            <h3>Thirukkural</h3>
            <p>A standalone heavily weighted topic. Focus on its secular nature, administrative principles, and everyday ethics. Memorizing key couplets is a major advantage.</p>
          </div>
          <div class="focus-card">
            <div class="focus-icon">✍️</div>
            <h3>Authors & Pen Names</h3>
            <p>Match the following questions frequently test the real names, pen names, and titles conferred upon modern writers (e.g., Kavimani, Namakkal Kavignar).</p>
          </div>
        </div>
      </section>

      <!-- Call to Action -->
      <section class="cta-section">
        <h2>Ready to Master Unit 8?</h2>
        <p>Access our curated quiz bank containing hundreds of previous year questions (PYQs) focused specifically on Tamil Literature and Culture.</p>
        <a href="/pyq" class="cta-btn">Start PYQ Practice <span class="arrow">→</span></a>
      </section>
    </div>
  </main>
</Layout>

<style>
  /* Base Variables overridden locally */
  :root {
    --accent-red: #C1121F;
    --dark-navy: #14213D;
    --cream: #FDFBF7;
    --gold: #D4AF37;
  }

  main {
    background: var(--bg);
    min-height: 100vh;
    padding-bottom: 4rem;
  }

  /* Hero Section */
  .lit-hero {
    position: relative;
    padding: 6rem 0 4rem;
    overflow: hidden;
    background: var(--dark-navy);
    color: white;
    border-bottom: 4px solid var(--accent-red);
  }

  .lit-hero-bg {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: 
      radial-gradient(circle at 15% 50%, rgba(193, 18, 31, 0.15), transparent 40%),
      radial-gradient(circle at 85% 30%, rgba(212, 175, 55, 0.1), transparent 40%);
    background-size: cover;
    z-index: 0;
  }

  .lit-hero::before {
    content: "தமிழ்";
    position: absolute;
    right: -5%;
    bottom: -20%;
    font-size: 20rem;
    font-weight: 900;
    color: rgba(255, 255, 255, 0.03);
    z-index: 0;
    pointer-events: none;
    font-family: sans-serif;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    max-width: 900px;
  }

  .badge {
    display: inline-block;
    padding: 0.4rem 1rem;
    background: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 50px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 1px;
    text-transform: uppercase;
    margin-bottom: 1.5rem;
    backdrop-filter: blur(4px);
  }

  .lit-hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.1;
    margin-bottom: 1.2rem;
  }

  .text-gradient {
    background: linear-gradient(120deg, #ffd700, #ff8c00);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    font-size: 1.15rem;
    line-height: 1.7;
    color: rgba(255, 255, 255, 0.8);
    max-width: 700px;
    margin-bottom: 3rem;
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1rem;
  }

  .stat-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    backdrop-filter: blur(10px);
    transition: transform 0.3s ease;
  }

  .stat-card:hover {
    transform: translateY(-5px);
    background: rgba(255, 255, 255, 0.08);
  }

  .stat-value {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: #ffd700;
    line-height: 1;
  }

  .stat-info {
    display: flex;
    flex-direction: column;
  }

  .stat-label {
    font-weight: 600;
    font-size: 0.95rem;
    color: #fff;
  }

  .stat-desc {
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .main-content {
    margin-top: 4rem;
  }

  /* Intro Section */
  .intro-section {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem;
    align-items: center;
    margin-bottom: 5rem;
  }

  .intro-text h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    color: var(--dark-navy);
    margin-bottom: 1.2rem;
  }

  .intro-text p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text);
  }

  .kural-box {
    background: linear-gradient(135deg, #fef3c7, #fde68a);
    padding: 2.5rem;
    border-radius: 16px;
    box-shadow: 0 10px 30px rgba(217, 119, 6, 0.15);
    position: relative;
    border: 1px solid #fcd34d;
  }

  .kural-box::before {
    content: "❝";
    position: absolute;
    top: -10px;
    left: 20px;
    font-size: 4rem;
    color: rgba(217, 119, 6, 0.2);
    font-family: serif;
    line-height: 1;
  }

  .kural-tamil {
    font-size: 1.25rem;
    font-weight: 600;
    color: #92400e;
    line-height: 1.6;
    margin-bottom: 1rem;
    font-family: 'Anek Tamil', sans-serif;
  }

  .kural-en {
    font-size: 0.95rem;
    color: #b45309;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .kural-meaning {
    font-size: 0.95rem;
    color: #78350f;
    font-style: italic;
  }

  /* Section Headers */
  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    color: var(--dark-navy);
    margin-bottom: 0.5rem;
  }

  .section-header p {
    font-size: 1.1rem;
    color: var(--muted);
  }

  /* Timeline */
  .timeline-section {
    margin-bottom: 6rem;
  }

  .timeline {
    position: relative;
    max-width: 800px;
    margin: 0 auto;
  }

  .timeline::before {
    content: '';
    position: absolute;
    top: 0; bottom: 0; left: 24px;
    width: 3px;
    background: var(--border);
    border-radius: 3px;
  }

  .timeline-item {
    position: relative;
    padding-left: 4.5rem;
    margin-bottom: 3rem;
  }

  .timeline-item:last-child {
    margin-bottom: 0;
  }

  .timeline-marker {
    position: absolute;
    left: 17px;
    top: 10px;
    width: 17px;
    height: 17px;
    border-radius: 50%;
    background: var(--era-color);
    border: 4px solid var(--surface);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--era-color) 20%, transparent);
    z-index: 2;
  }

  .timeline-content {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 1.75rem;
    box-shadow: 0 4px 20px rgba(0,0,0,0.03);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    border-left: 4px solid var(--era-color);
  }

  .timeline-content:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
  }

  .era-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .era-icon {
    font-size: 2.2rem;
    background: color-mix(in srgb, var(--era-color) 10%, var(--surface));
    width: 60px; height: 60px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 12px;
  }

  .era-titles h3 {
    font-size: 1.4rem;
    color: var(--dark-navy);
    margin: 0 0 0.25rem 0;
  }

  .era-period {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--era-color);
    background: color-mix(in srgb, var(--era-color) 15%, transparent);
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    display: inline-block;
  }

  .era-desc {
    color: var(--text);
    margin-bottom: 1.2rem;
    line-height: 1.6;
  }

  .era-features {
    background: var(--bg);
    padding: 1rem 1.25rem;
    border-radius: 8px;
    border: 1px solid var(--border);
  }

  .era-features h4 {
    font-size: 0.85rem;
    color: var(--muted);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin: 0 0 0.5rem 0;
  }

  .era-features ul {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--dark-navy);
    font-weight: 500;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.5rem;
  }

  /* Exam Focus Grid */
  .exam-focus-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 24px;
    padding: 4rem 3rem;
    margin-bottom: 6rem;
    box-shadow: 0 10px 40px rgba(0,0,0,0.02);
  }

  .exam-focus-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    text-align: center;
    margin-bottom: 3rem;
    color: var(--dark-navy);
  }

  .focus-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
  }

  .focus-card {
    background: var(--bg);
    padding: 2rem;
    border-radius: 16px;
    text-align: center;
    border: 1px solid var(--border);
    transition: all 0.3s ease;
  }

  .focus-card:hover {
    border-color: var(--accent-red);
    box-shadow: 0 10px 30px color-mix(in srgb, var(--accent-red) 10%, transparent);
  }

  .focus-icon {
    font-size: 2.5rem;
    margin-bottom: 1.2rem;
  }

  .focus-card h3 {
    font-size: 1.2rem;
    margin-bottom: 0.8rem;
    color: var(--dark-navy);
  }

  .focus-card p {
    font-size: 0.95rem;
    color: var(--muted);
    line-height: 1.6;
  }

  /* CTA */
  .cta-section {
    text-align: center;
    background: linear-gradient(135deg, var(--accent-red), #900c17);
    padding: 4rem 2rem;
    border-radius: 24px;
    color: white;
    box-shadow: 0 20px 40px rgba(193, 18, 31, 0.2);
  }

  .cta-section h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2.5rem;
    margin-bottom: 1rem;
    color: white;
  }

  .cta-section p {
    font-size: 1.1rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto 2rem;
    line-height: 1.6;
  }

  .cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: var(--accent-red);
    padding: 1rem 2rem;
    border-radius: 50px;
    font-weight: 700;
    font-size: 1.1rem;
    text-decoration: none;
    transition: all 0.3s ease;
  }

  .cta-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.1);
  }

  .cta-btn .arrow {
    transition: transform 0.3s;
  }

  .cta-btn:hover .arrow {
    transform: translateX(5px);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .intro-section {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    .lit-hero {
      padding: 4rem 0 3rem;
    }
    .exam-focus-section {
      padding: 3rem 1.5rem;
    }
  }

  @media (max-width: 480px) {
    .timeline::before {
      left: 15px;
    }
    .timeline-marker {
      left: 8px;
    }
    .timeline-item {
      padding-left: 3rem;
    }
    .timeline-content {
      padding: 1.25rem;
    }
    .era-features ul {
      grid-template-columns: 1fr;
    }
  }
</style>
