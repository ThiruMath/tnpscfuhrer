---
import jobs from "../data/jobs.json";

type Job = {
  notification_no: string;
  post_name: string;
  apply_from: string;
  apply_to: string;
  exam_date: string;
  link: string;
};

const jobList = jobs as Job[];

const today = new Date();

function parseDate(dateStr: string) {
  const parts = dateStr.split("/");
  return new Date(Number(parts[2]), Number(parts[1]) - 1, Number(parts[0]));
}

const upcoming = jobList.filter((job) => {
  const d = parseDate(job.exam_date);
  return d >= today;
});

const old = jobList.filter((job) => {
  const d = parseDate(job.exam_date);
  return d < today;
});

function googleCalendarLink(title: string, date: string) {

  const d = parseDate(date);

  const y = d.getFullYear();
  const m = String(d.getMonth()+1).padStart(2,'0');
  const day = String(d.getDate()).padStart(2,'0');

  const formatted = `${y}${m}${day}`;

  return `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${encodeURIComponent(title)}&dates=${formatted}/${formatted}`;
}
---

<style>

.container{
max-width:1200px;
margin:auto;
padding:40px;
font-family:Inter,system-ui;
}

h1{
margin-bottom:20px;
}

.section{
margin-top:40px;
}

table{
width:100%;
border-collapse:collapse;
background:white;
border-radius:12px;
overflow:hidden;
box-shadow:0 10px 30px rgba(0,0,0,0.05);
}

thead{
background:#2563eb;
color:white;
}

th,td{
padding:14px;
text-align:left;
}

tbody tr{
border-bottom:1px solid #eee;
}

tbody tr:hover{
background:#f9fafb;
}

.btn{
background:#2563eb;
color:white;
padding:6px 10px;
border-radius:6px;
text-decoration:none;
font-size:12px;
}

</style>

<div class="container">

<h1>TNPSC Job Dashboard</h1>

<div class="section">

<h2>Upcoming Notifications</h2>

<table>

<thead>

<tr>
<th>No</th>
<th>Notification</th>
<th>Post</th>
<th>Apply</th>
<th>Exam</th>
<th>Link</th>
<th>Calendar</th>
</tr>

</thead>

<tbody>

{upcoming.map((job,i)=>(

<tr>

<td>{i+1}</td>

<td>{job.notification_no}</td>

<td>{job.post_name}</td>

<td>{job.apply_from} → {job.apply_to}</td>

<td>{job.exam_date}</td>

<td>
<a class="btn" href={job.link} target="_blank">
View
</a>
</td>

<td>
<a class="btn" href={googleCalendarLink(job.post_name, job.exam_date)} target="_blank">
Add
</a>
</td>

</tr>

))}

</tbody>

</table>

</div>

<div class="section">

<h2>Old Notifications</h2>

<table>

<thead>

<tr>
<th>No</th>
<th>Notification</th>
<th>Post</th>
<th>Apply</th>
<th>Exam</th>
<th>Link</th>
</tr>

</thead>

<tbody>

{old.map((job,i)=>(

<tr>

<td>{i+1}</td>

<td>{job.notification_no}</td>

<td>{job.post_name}</td>

<td>{job.apply_from} → {job.apply_to}</td>

<td>{job.exam_date}</td>

<td>
<a class="btn" href={job.link} target="_blank">
View
</a>
</td>

</tr>

))}

</tbody>

</table>

</div>

</div>