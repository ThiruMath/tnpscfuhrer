---
import Layout from '../layouts/Layout.astro';
import jobsData from '../data/jobs.json';

interface Job {
  notification_no: string;
  post_name: string;
  apply_from: string;
  apply_to: string;
  exam_date: string;
  link: string;
  addendum_link?: string;
  corrigendum_link?: string;
}

interface ProcessedJob extends Job {
  isUrgent: boolean;
  isSoon: boolean;
  applyOpen: boolean;
  applyUrgent: boolean;
  examDays: number | null;
  applyDays: number | null;
  examDaysLabel: string;
  applyDaysLabel: string;
  gcalLink: string;
  examDateFmt: string;
  applyFromFmt: string;
  applyToFmt: string;
}

const jobs: Job[] = jobsData as Job[];
const today = new Date();
today.setHours(0, 0, 0, 0);

function parseDate(dateStr: string): Date | null {
  if (!dateStr || dateStr === '-' || dateStr === 'N/A' || !dateStr.trim()) return null;
  const parts = dateStr.split('/');
  if (parts.length === 3) {
    return new Date(parseInt(parts[2]), parseInt(parts[1]) - 1, parseInt(parts[0]));
  }
  const d = new Date(dateStr);
  return isNaN(d.getTime()) ? null : d;
}

function formatDate(dateStr: string): string {
  const d = parseDate(dateStr);
  if (!d) return '—';
  return d.toLocaleDateString('en-IN', { day: '2-digit', month: 'short', year: 'numeric' });
}

function getDaysUntil(dateStr: string): number | null {
  const d = parseDate(dateStr);
  if (!d) return null;
  return Math.ceil((d.getTime() - today.getTime()) / (1000 * 60 * 60 * 24));
}

function getGCalLink(job: Job): string {
  const examDate = parseDate(job.exam_date);
  if (!examDate) return '#';
  const fmt = (d: Date) =>
    `${d.getFullYear()}${String(d.getMonth() + 1).padStart(2, '0')}${String(d.getDate()).padStart(2, '0')}`;
  const start = fmt(examDate);
  const end = fmt(new Date(examDate.getTime() + 86400000));
  const title = encodeURIComponent(`TNPSC - ${job.post_name}`);
  const details = encodeURIComponent(`Notification: ${job.notification_no}\nLink: ${job.link}`);
  return `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${title}&dates=${start}/${end}&details=${details}`;
}

function processJob(job: Job): ProcessedJob {
  const examDays = getDaysUntil(job.exam_date);
  const applyDays = getDaysUntil(job.apply_to);
  const isUrgent = examDays !== null && examDays >= 0 && examDays <= 7;
  const isSoon = examDays !== null && examDays >= 0 && examDays <= 30 && !isUrgent;
  const applyOpen = applyDays !== null && applyDays >= 0;
  const applyUrgent = applyDays !== null && applyDays >= 0 && applyDays <= 5;

  let examDaysLabel = '';
  if (examDays !== null && examDays >= 0) {
    if (examDays === 0) examDaysLabel = 'Today!';
    else if (examDays === 1) examDaysLabel = 'Tomorrow';
    else examDaysLabel = `${examDays}d`;
  }

  let applyDaysLabel = '';
  if (applyDays !== null && applyDays >= 0 && applyDays <= 7) {
    applyDaysLabel = `${applyDays}d`;
  }

  return {
    ...job,
    isUrgent,
    isSoon,
    applyOpen,
    applyUrgent,
    examDays,
    applyDays,
    examDaysLabel,
    applyDaysLabel,
    gcalLink: getGCalLink(job),
    examDateFmt: formatDate(job.exam_date),
    applyFromFmt: formatDate(job.apply_from),
    applyToFmt: formatDate(job.apply_to),
  };
}

const allProcessed = jobs.map(processJob);

const upcomingJobs = allProcessed
  .filter(j => {
    const d = parseDate(j.exam_date);
    return !d || d >= today;
  })
  .sort((a, b) => {
    const da = parseDate(a.exam_date);
    const db = parseDate(b.exam_date);
    if (!da && !db) return 0;
    if (!da) return 1;
    if (!db) return -1;
    return da.getTime() - db.getTime();
  });

const oldJobs = allProcessed
  .filter(j => {
    const d = parseDate(j.exam_date);
    return d && d < today;
  })
  .sort((a, b) => {
    const da = parseDate(a.exam_date)!;
    const db = parseDate(b.exam_date)!;
    return db.getTime() - da.getTime();
  });

const calendarItems = upcomingJobs
  .filter(j => parseDate(j.exam_date) !== null)
  .slice(0, 8)
  .map(j => {
    const d = parseDate(j.exam_date)!;
    const days = j.examDays;
    let cdClass = '';
    let cdLabel = '';
    if (days !== null && days >= 0) {
      if (days <= 7) cdClass = 'urgent';
      else if (days <= 30) cdClass = 'near';
      if (days === 0) cdLabel = 'Today!';
      else if (days === 1) cdLabel = 'Tomorrow';
      else cdLabel = `${days}d left`;
    }
    return {
      ...j,
      calDay: String(d.getDate()).padStart(2, '0'),
      calMonth: d.toLocaleString('en', { month: 'short' }),
      cdClass,
      cdLabel,
    };
  });

const lastUpdated = new Date().toLocaleDateString('en-IN', {
  day: '2-digit', month: 'short', year: 'numeric',
  hour: '2-digit', minute: '2-digit'
});
---

<Layout title="TNPSC Job Notifications | TNPSC Fuhrer">
  <div class="dashboard">

    <header class="site-header">
      <div class="header-inner">
        <div class="brand">
          <span>⚡</span>
          <span>TNPSC<span class="brand-accent">fuhrer</span></span>
        </div>
        <nav class="nav-links">
          <a href="/" class="nav-link">Home</a>
          <a href="/jobs" class="nav-link active">Jobs</a>
          <a href="/notes" class="nav-link nav-soon">Notes <span class="badge">Soon</span></a>
          <a href="/quiz" class="nav-link nav-soon">Quiz <span class="badge">Soon</span></a>
          <a href="/current-affairs" class="nav-link nav-soon">Current Affairs <span class="badge">Soon</span></a>
        </nav>
        <button class="theme-toggle" id="themeToggle" aria-label="Toggle theme">
          <span id="themeIcon">☀️</span>
        </button>
      </div>
    </header>

    <section class="hero">
      <div class="hero-inner">
        <div class="hero-text">
          <div class="hero-eyebrow">Tamil Nadu Public Service Commission</div>
          <h1 class="hero-title">Exam Notifications<br/><span class="hero-highlight">Dashboard</span></h1>
          <p class="hero-sub">Live job notifications, exam dates, and calendar integration — automatically updated every 6 hours.</p>
          <div class="hero-stats">
            <div class="stat">
              <span class="stat-num">{upcomingJobs.length}</span>
              <span class="stat-label">Upcoming</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-num">{oldJobs.length}</span>
              <span class="stat-label">Archived</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-num">{jobs.length}</span>
              <span class="stat-label">Total</span>
            </div>
          </div>
        </div>

        <div class="hero-cal">
          <div class="cw-head">
            <span>📅</span>
            <span class="cw-title">Upcoming Exams</span>
          </div>
          <div class="cal-list">
            {calendarItems.length === 0 && (
              <div class="cal-empty">No upcoming exams scheduled</div>
            )}
            {calendarItems.map((item) => (
              <div class="cal-item">
                <div class="cal-date">
                  <span class="cal-day">{item.calDay}</span>
                  <span class="cal-mo">{item.calMonth}</span>
                </div>
                <div class="cal-info">
                  <span class="cal-post">{item.post_name}</span>
                  {item.cdLabel && (
                    <span class={`cal-cd ${item.cdClass}`}>{item.cdLabel}</span>
                  )}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <div class="toolbar-wrap">
      <div class="toolbar">
        <div class="search-box">
          <span class="search-icon">🔍</span>
          <input type="text" id="searchInput" placeholder="Search notifications, posts..." class="search-input" />
          <kbd class="search-kbd">Ctrl+K</kbd>
        </div>
        <div class="filter-pills">
          <button class="pill active" data-filter="all">All</button>
          <button class="pill" data-filter="upcoming">Upcoming</button>
          <button class="pill" data-filter="old">Archived</button>
        </div>
        <div class="updated-badge">
          <span class="udot"></span>
          Updated {lastUpdated}
        </div>
      </div>
    </div>

    <main class="main-content">

      <section id="upcomingSection">
        <div class="section-header">
          <div class="section-title-group">
            <span>🟢</span>
            <h2 class="section-title">Upcoming Notifications</h2>
            <span class="count-badge">{upcomingJobs.length}</span>
          </div>
          <p class="section-sub">Active and forthcoming TNPSC exam notifications</p>
        </div>

        {upcomingJobs.length === 0 && (
          <div class="empty-state">
            <div class="empty-icon">📭</div>
            <p>No upcoming notifications found.</p>
          </div>
        )}

        <div class="jobs-grid" id="upcomingGrid">
          {upcomingJobs.map((job) => (
            <div
              class={`job-card ${job.isUrgent ? 'urgent' : job.isSoon ? 'soon' : ''}`}
              data-post={job.post_name.toLowerCase()}
              data-notif={job.notification_no.toLowerCase()}
            >
              <div class="card-head">
                <span class="notif-no">{job.notification_no}</span>
                <div class="card-badges">
                  {job.isUrgent && <span class="tag tag-urgent">Urgent</span>}
                  {job.isSoon && <span class="tag tag-soon">Soon</span>}
                  {job.applyOpen && <span class="tag tag-apply">Apply Open</span>}
                  {job.addendum_link && <span class="tag tag-add">Addendum</span>}
                  {job.corrigendum_link && <span class="tag tag-corr">Corrigendum</span>}
                </div>
              </div>
              <div class="card-body">
                <h3 class="post-name">{job.post_name}</h3>
                <div class="dates-grid">
                  <div class="date-item">
                    <span class="date-label">Apply From</span>
                    <span class="date-val">{job.applyFromFmt}</span>
                  </div>
                  <div class="date-item">
                    <span class="date-label">Last Date</span>
                    <span class={`date-val ${job.applyUrgent ? 'red' : ''}`}>
                      {job.applyToFmt}
                      {job.applyDaysLabel && <span class="dchip">{job.applyDaysLabel}</span>}
                    </span>
                  </div>
                  <div class="date-item date-full">
                    <span class="date-label">Exam Date</span>
                    <span class="date-val amber">
                      {job.examDateFmt}
                      {job.examDaysLabel && (
                        <span class={`dchip ${job.isUrgent ? 'red' : ''}`}>{job.examDaysLabel}</span>
                      )}
                    </span>
                  </div>
                </div>
              </div>
              <div class="card-foot">
                <a href={job.link} target="_blank" rel="noopener" class="btn btn-primary">
                  View Notification ↗
                </a>
                {job.addendum_link && (
                  <a href={job.addendum_link} target="_blank" rel="noopener" class="btn btn-add">Addendum ↗</a>
                )}
                {job.corrigendum_link && (
                  <a href={job.corrigendum_link} target="_blank" rel="noopener" class="btn btn-corr">Corrigendum ↗</a>
                )}
                {job.exam_date && job.exam_date !== '-' && (
                  <a href={job.gcalLink} target="_blank" rel="noopener" class="btn btn-cal">📅 Calendar</a>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>

      <section id="oldSection">
        <div class="archived-header">
          <div class="section-title-group">
            <span>🔘</span>
            <h2 class="section-title">Archived Notifications</h2>
            <span class="count-badge muted">{oldJobs.length}</span>
          </div>
          <p class="section-sub">Past exam notifications for reference</p>
          <button class="toggle-btn" id="toggleArchived">Show Archived ↓</button>
        </div>
        <div class="jobs-grid hidden" id="archivedGrid">
          {oldJobs.map((job) => (
            <div
              class="job-card archived"
              data-post={job.post_name.toLowerCase()}
              data-notif={job.notification_no.toLowerCase()}
            >
              <div class="card-head">
                <span class="notif-no">{job.notification_no}</span>
                <div class="card-badges">
                  <span class="tag tag-old">Completed</span>
                  {job.addendum_link && <span class="tag tag-add">Addendum</span>}
                  {job.corrigendum_link && <span class="tag tag-corr">Corrigendum</span>}
                </div>
              </div>
              <div class="card-body">
                <h3 class="post-name">{job.post_name}</h3>
                <div class="dates-grid">
                  <div class="date-item">
                    <span class="date-label">Applied</span>
                    <span class="date-val" style="font-size:12px">{job.applyFromFmt} – {job.applyToFmt}</span>
                  </div>
                  <div class="date-item">
                    <span class="date-label">Exam Was</span>
                    <span class="date-val">{job.examDateFmt}</span>
                  </div>
                </div>
              </div>
              <div class="card-foot">
                <a href={job.link} target="_blank" rel="noopener" class="btn btn-ghost">View Notification ↗</a>
                {job.addendum_link && (
                  <a href={job.addendum_link} target="_blank" rel="noopener" class="btn btn-ghost">Addendum ↗</a>
                )}
                {job.corrigendum_link && (
                  <a href={job.corrigendum_link} target="_blank" rel="noopener" class="btn btn-ghost">Corrigendum ↗</a>
                )}
              </div>
            </div>
          ))}
        </div>
      </section>

    </main>

    <footer class="site-footer">
      <div class="footer-inner">
        <div class="footer-brand">⚡ TNPSC<span class="brand-accent">fuhrer</span></div>
        <p class="footer-note">
          Data sourced from <a href="https://www.tnpsc.gov.in" target="_blank" rel="noopener">tnpsc.gov.in</a>
          · Updated every 6 hours via GitHub Actions
        </p>
        <div class="footer-pills">
          <span class="footer-pill">🧠 Notes — Coming Soon</span>
          <span class="footer-pill">🧩 Quiz Engine — Coming Soon</span>
          <span class="footer-pill">📰 Current Affairs AI — Coming Soon</span>
        </div>
      </div>
    </footer>

  </div>
</Layout>

<script>
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  searchInput?.addEventListener('input', () => {
    const q = searchInput.value.toLowerCase().trim();
    document.querySelectorAll<HTMLElement>('.job-card').forEach(card => {
      const match = (card.dataset.post || '').includes(q) || (card.dataset.notif || '').includes(q);
      card.style.display = match ? '' : 'none';
    });
  });
  document.addEventListener('keydown', e => {
    if ((e.metaKey || e.ctrlKey) && e.key === 'k') { e.preventDefault(); searchInput?.focus(); }
  });

  document.querySelectorAll('.pill').forEach(pill => {
    pill.addEventListener('click', () => {
      document.querySelectorAll('.pill').forEach(p => p.classList.remove('active'));
      pill.classList.add('active');
      const f = (pill as HTMLElement).dataset.filter;
      const up = document.getElementById('upcomingSection')!;
      const od = document.getElementById('oldSection')!;
      up.style.display = f === 'old' ? 'none' : '';
      od.style.display = f === 'upcoming' ? 'none' : '';
      if (f === 'old') {
        document.getElementById('archivedGrid')?.classList.remove('hidden');
        const btn = document.getElementById('toggleArchived');
        if (btn) btn.textContent = 'Hide Archived ↑';
      }
    });
  });

  const toggleBtn = document.getElementById('toggleArchived')!;
  const archivedGrid = document.getElementById('archivedGrid')!;
  toggleBtn?.addEventListener('click', () => {
    archivedGrid.classList.toggle('hidden');
    toggleBtn.textContent = archivedGrid.classList.contains('hidden') ? 'Show Archived ↓' : 'Hide Archived ↑';
  });

  let dark = true;
  document.getElementById('themeToggle')?.addEventListener('click', () => {
    dark = !dark;
    document.documentElement.setAttribute('data-theme', dark ? 'dark' : 'light');
    const icon = document.getElementById('themeIcon');
    if (icon) icon.textContent = dark ? '☀️' : '🌙';
  });
</script>

<style>
  .jobs-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(360px, 1fr)); gap: 16px; }
  .hidden { display: none !important; }
  .date-full { grid-column: 1 / -1; }
  @media (max-width: 640px) { .jobs-grid { grid-template-columns: 1fr; } }
</style>