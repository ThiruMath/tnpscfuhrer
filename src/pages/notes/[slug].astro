---
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const notes = await getCollection("notes");

  return notes.map((note) => ({
    params: { slug: note.id },
    props: { note }
  }));
}

const { note } = Astro.props;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>{note.id.replace(/_/g, " ")}</title>
</head>

<body>

<h1>{note.id.replace(/_/g, " ")}</h1>

<article set:html={note.rendered?.html}></article>

</body>
</html>