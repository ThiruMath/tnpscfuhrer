---
import news from "../../../public/data/news.json";
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Current Affairs | TNPSC Fuhrer</title>
  <style>
    body { font-family: 'DM Sans', sans-serif; background: #F8F7F4; color: #1C1C1C; margin: 0; padding: 2rem; }
    .container { max-width: 800px; margin: 0 auto; }
    .card { background: #fff; border: 1px solid #E8E5DF; padding: 1.5rem; border-radius: 12px; margin-bottom: 1rem; box-shadow: 0 2px 8px rgba(0,0,0,0.05); }
    .card h2 { margin-top: 0; color: #14213D; }
    .tag { display: inline-block; background: #FFF0F0; color: #C1121F; padding: 0.2rem 0.6rem; border-radius: 4px; font-size: 0.8rem; font-weight: bold; margin-bottom: 1rem; }
    a { color: #1d4ed8; text-decoration: none; font-weight: bold; }
    a:hover { text-decoration: underline; }
  </style>
</head>
<body>
  <div class="container">
    <h1>Current Affairs (Daily Generator)</h1>
    <p><a href="/">← Back Home</a></p>
    
    {news.map((item) => (
      <div class="card">
        <span class="tag">{item.topic}</span>
        <h2>{item.title}</h2>
        <p>{item.summary}</p>
        <a href={`/current-affairs/${item.slug}`}>Read Full Details & Practice →</a>
      </div>
    ))}

    {news.length === 0 && <p>No news available today.</p>}
  </div>
</body>
</html>
