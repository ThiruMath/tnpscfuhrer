---
import Layout from '../layouts/Layout.astro';
---

<Layout title="TNPSC Fuhrer – Free Study Notes, Jobs & Current Affairs" active="Home">
  <main>
    <!-- Hero – 2 column -->
    <section class="hero">
      <div class="container">
        <div class="hero-grid">
          <!-- Left: Headline -->
          <div class="hero-left">
            <span class="badge">Free &amp; Open Platform</span>
            <h1>Crack TNPSC.<br/>Study Smarter.</h1>
            <p>Notes, job alerts, current affairs, and exam guides — everything you need to clear Group 2, 2A, 4 &amp; VAO in one place.</p>
            <div class="hero-actions">
              <a href="/notes" class="btn-primary">Browse Notes</a>
              <a href="/jobs" class="btn-outline">Latest Jobs</a>
            </div>
            <div class="hero-stats">
              <div class="stat"><span>900+</span><p>Study Notes</p></div>
              <div class="stat"><span>Daily</span><p>Job Updates</p></div>
              <div class="stat"><span>Free</span><p>Forever</p></div>
            </div>
          </div>

          <!-- Right: Live News Panel (client-side populated) -->
          <div class="news-panel">
            <div class="news-panel-header">
              <div class="news-panel-title">
                <span class="live-dot"></span>
                <span>Today's Exam News</span>
              </div>
              <span class="news-date" id="newsDate"></span>
            </div>

            <!-- Skeleton loader -->
            <div class="news-scroll" id="newsFeed">
              <div class="skeleton-wrap">
                {Array.from({length: 4}).map(() => (
                  <div class="skeleton-item">
                    <div class="sk sk-tag"></div>
                    <div class="sk sk-title"></div>
                    <div class="sk sk-title sk-short"></div>
                    <div class="sk sk-body"></div>
                    <div class="sk-tags-row"><div class="sk sk-chip"></div><div class="sk sk-chip"></div></div>
                  </div>
                ))}
              </div>
            </div>

            <a href="/current-affairs" class="news-footer">View all Current Affairs →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features">
      <div class="container">
        <h2>Everything You Need</h2>
        <div class="features-grid">
          <a href="/notes" class="feature-card">
            <div class="feature-icon">📚</div>
            <h3>Study Notes</h3>
            <p>Concise, exam-focused notes covering all TNPSC subjects — History, Polity, Economy, Science, and Tamil.</p>
          </a>
          <a href="/syllabus" class="feature-card">
            <div class="feature-icon">📋</div>
            <h3>Syllabus</h3>
            <p>Complete Group II/IIA syllabus with unit-wise breakdown, topic lists, and linked study notes.</p>
          </a>
          <a href="/jobs" class="feature-card">
            <div class="feature-icon">💼</div>
            <h3>Job Alerts</h3>
            <p>Latest TN government job notifications, exam dates, and application deadlines — updated daily.</p>
          </a>
          <a href="/tnpsc" class="feature-card">
            <div class="feature-icon">🎯</div>
            <h3>TNPSC Guide</h3>
            <p>Everything about TNPSC — exam pattern, syllabus, group-wise eligibility, and preparation roadmap.</p>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  // Tag → color map
  const TAG_COLORS: Record<string, string> = {
    'Polity': '#14213D', 'Economy': '#0a6e4f', 'Science & Tech': '#7c3aed',
    'Environment': '#0369a1', 'History & Culture': '#C1121F', 'Education': '#d97706',
    'Health': '#be185d', 'Agriculture': '#15803d', 'Awards & Sports': '#ea580c',
    'Defence': '#374151', 'Tamil Nadu': '#9f1239', 'International': '#0891b2',
  };

  function makeTag(tag: string) {
    const c = TAG_COLORS[tag] || '#6b7280';
    const span = document.createElement('span');
    span.className = 'news-tag';
    span.textContent = tag;
    span.style.cssText = `--tc:${c};background:color-mix(in srgb,${c} 10%,white);color:${c};border:1px solid color-mix(in srgb,${c} 25%,transparent)`;
    return span;
  }

  function renderNews(items: any[]) {
    const feed = document.getElementById('newsFeed')!;
    feed.innerHTML = '';
    if (!items || items.length === 0) {
      feed.innerHTML = `<div class="news-fallback"><div class="fallback-icon">📡</div><p>News is loading…</p><a href="/notes" class="fallback-link">Browse Study Notes instead →</a></div>`;
      return;
    }
    items.forEach((item, i) => {
      const a = document.createElement('a');
      a.href = item.link;
      a.target = '_blank';
      a.rel = 'noopener noreferrer';
      a.className = 'news-item';
      a.style.setProperty('--ni', String(i));

      const metaDiv = document.createElement('div');
      metaDiv.className = 'news-meta';
      const srcSpan = document.createElement('span');
      srcSpan.className = 'news-source';
      srcSpan.textContent = item.source;
      const timeSpan = document.createElement('span');
      timeSpan.className = 'news-time';
      timeSpan.textContent = item.date;
      metaDiv.append(srcSpan, timeSpan);

      const h4 = document.createElement('h4');
      h4.className = 'news-headline';
      h4.textContent = item.title;

      const inner = document.createElement('div');
      inner.className = 'news-item-inner';
      inner.append(metaDiv, h4);

      if (item.summary) {
        const p = document.createElement('p');
        p.className = 'news-summary';
        p.textContent = item.summary;
        inner.append(p);
      }

      if (item.tags?.length) {
        const tagsDiv = document.createElement('div');
        tagsDiv.className = 'news-tags';
        item.tags.forEach((t: string) => tagsDiv.append(makeTag(t)));
        inner.append(tagsDiv);
      }

      const arrow = document.createElement('span');
      arrow.className = 'news-arrow';
      arrow.textContent = '↗';

      a.append(inner, arrow);
      feed.append(a);
    });
  }

  // TNPSC syllabus auto-tag rules
  const TAGS: [RegExp, string][] = [
    [/parliament|lok sabha|rajya sabha|president|governor|cabinet|minister|constitution|panchayat|election/i, 'Polity'],
    [/economy|budget|gdp|inflation|rbi|bank|rupee|tax|gst|fiscal|monetary|finance/i, 'Economy'],
    [/science|technology|isro|space|satellite|research|artificial intelligence|\bai\b/i, 'Science & Tech'],
    [/climate|environment|pollution|renewable|solar|forest|wildlife|ecology/i, 'Environment'],
    [/exam|neet|tnpsc|upsc|scholarship|education|school|university/i, 'Education'],
    [/health|disease|vaccination|hospital|medicine|epidemic|nutrition/i, 'Health'],
    [/agriculture|farmer|crop|irrigation|fertilizer|soil/i, 'Agriculture'],
    [/award|prize|nobel|padma|bharat ratna|sport|olympic/i, 'Awards & Sports'],
    [/defence|army|navy|air force|missile|border|security/i, 'Defence'],
    [/tamilnadu|tamil nadu|chennai|tn government/i, 'Tamil Nadu'],
    [/international|united nations|g20|brics|imf|world bank|foreign/i, 'International'],
    [/history|heritage|culture|archaeological|museum/i, 'History & Culture'],
  ];

  function autoTag(text: string): string[] {
    const tags: string[] = [];
    for (const [re, tag] of TAGS) {
      if (re.test(text) && !tags.includes(tag)) tags.push(tag);
      if (tags.length >= 2) break;
    }
    return tags;
  }

  async function fetchRSS(rssUrl: string, source: string) {
    const apiUrl = `https://api.rss2json.com/v1/api.json?rss_url=${encodeURIComponent(rssUrl)}&count=4`;
    try {
      const res = await fetch(apiUrl, { signal: AbortSignal.timeout(5000) });
      if (!res.ok) return [];
      const data = await res.json();
      if (data.status !== 'ok' || !data.items) return [];
      return data.items.map((item: any) => {
        const title = (item.title || '').slice(0, 130);
        const raw = (item.description || item.content || '').replace(/<[^>]*>/g,'').replace(/\s+/g,' ').trim();
        const summary = raw.length > 130 ? raw.slice(0, 130).replace(/\s+\S*$/, '') + '…' : raw;
        const tags = autoTag(title + ' ' + summary);
        const date = item.pubDate ? new Date(item.pubDate).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) : '';
        return { title, link: item.link || '#', summary, tags, date, source };
      });
    } catch { return []; }
  }

  async function loadNews() {
    const results = await Promise.allSettled([
      fetchRSS('https://pib.gov.in/RssMain.aspx?ModId=6&Lang=1&Regid=3', 'PIB India'),
      fetchRSS('https://pib.gov.in/RssMain.aspx?ModId=7&Lang=1&Regid=3', 'PIB Economy'),
      fetchRSS('https://timesofindia.indiatimes.com/rssfeeds/296589292.cms', 'Times of India'),
    ]);

    const all: any[] = [];
    for (const r of results) {
      if (r.status === 'fulfilled') all.push(...r.value);
    }

    // Deduplicate
    const seen = new Set<string>();
    const news = all.filter(item => {
      const k = item.title.slice(0, 35).toLowerCase();
      if (seen.has(k)) return false;
      seen.add(k);
      return true;
    }).slice(0, 8);

    // Set date
    const dateEl = document.getElementById('newsDate');
    if (dateEl) {
      dateEl.textContent = new Date().toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' });
    }

    renderNews(news);
  }

  loadNews();

</script>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(160deg, #fff 0%, var(--bg) 100%);
    border-bottom: 1px solid var(--border);
    padding: 4.5rem 0 3.5rem;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: start;
  }

  /* Left */
  .hero-left { max-width: 500px; }
  .badge {
    display: inline-block;
    background: #fff0f0;
    color: var(--accent);
    border: 1px solid #ffc8c8;
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }
  .hero-left h1 {
    font-size: clamp(2.4rem, 4.5vw, 3.6rem);
    color: var(--navy);
    margin: 0 0 1rem;
    line-height: 1.08;
  }
  .hero-left > p {
    font-size: 1.08rem;
    color: var(--muted);
    max-width: 440px;
    line-height: 1.7;
    margin-bottom: 1.75rem;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; margin-bottom: 2.5rem; }
  .btn-primary {
    background: var(--accent); color: #fff;
    padding: 0.75rem 1.75rem; border-radius: 8px;
    font-weight: 700; font-size: 0.95rem;
    transition: opacity 0.15s, transform 0.15s;
  }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); }
  .btn-outline {
    background: transparent; color: var(--navy);
    padding: 0.75rem 1.75rem; border-radius: 8px;
    font-weight: 600; font-size: 0.95rem;
    border: 1.5px solid var(--border);
    transition: border-color 0.15s, transform 0.15s;
  }
  .btn-outline:hover { border-color: var(--navy); transform: translateY(-1px); }
  .hero-stats { display: flex; gap: 2.5rem; }
  .stat span {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem; font-weight: 700;
    color: var(--accent); display: block;
  }
  .stat p { color: var(--muted); font-size: 0.85rem; margin-top: 0.15rem; }

  /* News Panel */
  .news-panel {
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 18px;
    overflow: hidden;
    box-shadow: 0 4px 32px rgba(0,0,0,0.07);
    display: flex;
    flex-direction: column;
    max-height: 560px;
  }
  .news-panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1rem 1.25rem;
    background: linear-gradient(135deg, #14213D, #1d3461);
    color: #fff;
  }
  .news-panel-title {
    display: flex; align-items: center; gap: 0.6rem;
    font-size: 0.9rem; font-weight: 700;
  }
  .live-dot {
    width: 8px; height: 8px;
    background: #22c55e; border-radius: 50%;
    animation: livepulse 1.8s infinite;
    box-shadow: 0 0 0 0 #22c55e44;
  }
  @keyframes livepulse {
    0% { box-shadow: 0 0 0 0 #22c55e55; }
    70% { box-shadow: 0 0 0 7px #22c55e00; }
    100% { box-shadow: 0 0 0 0 #22c55e00; }
  }
  .news-date { font-size: 0.72rem; color: #9ca3af; }
  .news-scroll {
    overflow-y: auto; flex: 1;
    padding: 0.5rem 0;
    scrollbar-width: thin;
    scrollbar-color: var(--border) transparent;
  }
  .news-scroll::-webkit-scrollbar { width: 4px; }
  .news-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  /* Skeleton */
  .skeleton-wrap { padding: 0.25rem 0; }
  .skeleton-item {
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .sk {
    background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: shimmer 1.4s infinite;
    border-radius: 6px;
  }
  @keyframes shimmer { 0%{background-position:200% 0} 100%{background-position:-200% 0} }
  .sk-tag { height: 16px; width: 70px; border-radius: 100px; }
  .sk-title { height: 14px; width: 90%; }
  .sk-short { width: 65%; }
  .sk-body { height: 11px; width: 80%; opacity: 0.6; }
  .sk-tags-row { display: flex; gap: 0.4rem; }
  .sk-chip { height: 14px; width: 60px; border-radius: 100px; }

  /* News item */
  .news-item {
    display: flex; align-items: flex-start; gap: 0.5rem;
    padding: 0.9rem 1.25rem;
    border-bottom: 1px solid var(--border);
    text-decoration: none; color: inherit;
    transition: background 0.18s;
    animation: slideIn 0.35s ease both;
    animation-delay: calc(var(--ni, 0) * 55ms);
  }
  @keyframes slideIn { from{opacity:0;transform:translateY(6px)} to{opacity:1;transform:none} }
  .news-item:last-child { border-bottom: none; }
  .news-item:hover { background: color-mix(in srgb, var(--accent) 4%, var(--surface)); }
  .news-item-inner { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 0.3rem; }
  .news-meta { display: flex; align-items: center; gap: 0.5rem; }
  .news-source {
    font-size: 0.67rem; font-weight: 700;
    text-transform: uppercase; letter-spacing: 0.07em;
    color: var(--accent); background: #fff0f0;
    padding: 0.1rem 0.5rem; border-radius: 100px;
    border: 1px solid #ffc8c8;
  }
  .news-time { font-size: 0.67rem; color: var(--muted); }
  .news-headline {
    font-size: 0.88rem; font-weight: 600;
    color: var(--navy); line-height: 1.4; margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .news-summary {
    font-size: 0.77rem; color: var(--muted);
    line-height: 1.5; margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  }
  .news-tags { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .news-tag {
    font-size: 0.64rem; font-weight: 700;
    padding: 0.1rem 0.48rem; border-radius: 100px;
    letter-spacing: 0.03em;
  }
  .news-arrow {
    font-size: 0.9rem; color: var(--muted);
    transition: color 0.15s, transform 0.15s;
    flex-shrink: 0; align-self: center;
  }
  .news-item:hover .news-arrow { color: var(--accent); transform: translate(2px,-2px); }

  .news-footer {
    display: block; text-align: center;
    padding: 0.85rem; font-size: 0.82rem;
    font-weight: 600; color: var(--accent);
    background: #fff8f8; border-top: 1px solid var(--border);
    text-decoration: none; transition: background 0.15s;
  }
  .news-footer:hover { background: #fff0f0; }

  .news-fallback { text-align: center; padding: 3rem 1.5rem; color: var(--muted); }
  .fallback-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
  .news-fallback p { font-size: 0.9rem; line-height: 1.6; margin-bottom: 1rem; }
  .fallback-link { color: var(--accent); font-weight: 600; text-decoration: none; font-size: 0.88rem; }

  /* Features */
  .features { padding: 5rem 0; }
  .features h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem; color: var(--navy); margin-bottom: 2.5rem;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .feature-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 2rem 1.5rem;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
    text-decoration: none; color: inherit; display: block;
  }
  .feature-card:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    transform: translateY(-3px); border-color: #ffc8c8;
  }
  .feature-icon { font-size: 2rem; margin-bottom: 1rem; }
  .feature-card h3 { font-size: 1.1rem; color: var(--navy); margin-bottom: 0.6rem; }
  .feature-card p { font-size: 0.88rem; color: var(--muted); line-height: 1.65; }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; }
    .news-panel { max-height: 360px; }
  }
  @media (max-width: 600px) {
    .hero-stats { gap: 1.5rem; }
    .features-grid { grid-template-columns: 1fr 1fr; }
  }
</style>
