---

<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>TNPSC Fuhrer</title>

<style>

body{
font-family: system-ui;
margin:0;
background:#f6f8fb;
color:#111;
}

header{
background:#0b1b34;
color:white;
padding:20px 40px;
display:flex;
justify-content:space-between;
align-items:center;
}

.logo{
font-size:24px;
font-weight:bold;
color:#ffa500;
}

nav a{
color:white;
margin-left:20px;
text-decoration:none;
font-weight:500;
}

.hero{
text-align:center;
padding:80px 20px;
background:white;
}

.hero h1{
font-size:48px;
margin-bottom:10px;
}

.hero p{
font-size:18px;
color:#555;
}

.buttons{
margin-top:30px;
}

.btn{
background:#0b1b34;
color:white;
padding:12px 22px;
border-radius:6px;
text-decoration:none;
margin:10px;
display:inline-block;
}

.section{
padding:60px 40px;
max-width:1200px;
margin:auto;
}

.grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
}

.card{
background:white;
padding:30px;
border-radius:10px;
box-shadow:0 2px 8px rgba(0,0,0,0.06);
text-align:center;
font-weight:600;
}

footer{
text-align:center;
padding:30px;
background:#0b1b34;
color:white;
margin-top:60px;
}

</style>

</head>

<body>

<header>

<div class="logo">TNPSC FUHRER</div>

<nav>
<a href="/">Home</a>
<a href="/notes">Notes</a>
<a href="/quiz">Quiz</a>
<a href="/current-affairs">Current Affairs</a>
</nav>

</header>

<section class="hero">

<h1>Master TNPSC Preparation</h1>

<p>Free structured notes, quizzes and knowledge garden for TNPSC aspirants.</p>

<div class="buttons">
<a class="btn" href="/notes">Start Learning</a>
<a class="btn" href="/quiz">Practice Quiz</a>
</div>

</section>

<section class="section">

<h2>Subjects</h2>

<div class="grid">

<div class="card">History</div>
<div class="card">Polity</div>
<div class="card">Geography</div>
<div class="card">Economy</div>
<div class="card">Science</div>
<div class="card">Current Affairs</div>

</div>

</section>

<section class="section">

<h2>Latest Notes</h2>

<div class="grid">

<div class="card">Chola Dynasty</div>
<div class="card">Indian Constitution</div>
<div class="card">Tamil Nadu Rivers</div>

</div>

</section>

<footer>

<p>© 2026 TNPSC Fuhrer — Built for TNPSC Aspirants</p>

</footer>

</body>
</html>