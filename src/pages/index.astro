---
import Layout from '../layouts/Layout.astro';
import newsData from '../../public/data/news.json';

const topNews = newsData ? newsData.slice(0, 3) : [];
---

<Layout title="TNPSC Fuhrer – Free Study Notes, Jobs & Current Affairs" active="Home">
  <main>
    <!-- Hero – 2 column -->
    <section class="hero">
      <div class="container">
        <div class="hero-container">
          <!-- Left: Headline -->
          <div class="hero-left">
            <span class="badge">Free &amp; Open Platform</span>
            <h1 class="hero-title">Crack TNPSC.<br/>Study Smarter.</h1>
            <p class="hero-subtitle">Notes, job alerts, current affairs, and exam guides — everything you need to clear Group 2, 2A, 4 &amp; VAO in one place.</p>
            <div class="hero-buttons">
              <a href="/notes" class="btn-primary">Browse Notes</a>
              <a href="/jobs" class="btn-outline">Latest Jobs</a>
            </div>
            <div class="hero-stats">
              <div class="stat"><span>900+</span><p>Study Notes</p></div>
              <div class="stat"><span>Daily</span><p>Job Updates</p></div>
              <div class="stat"><span>Free</span><p>Forever</p></div>
            </div>
          </div>

          <!-- Right: Live News Panel (Statically rendered) -->
          <div class="news-right-col">
            <div class="exam-news-card">
              <div class="news-panel-header">
                <h3><span class="news-live-dot"></span> Today's Exam News</h3>
              </div>

              <div class="news-feed">
                {topNews.length > 0 ? topNews.map((item) => (
                  <div class="exam-news-item">
                    <div class="exam-news-meta">
                      {item.source} • {item.date ? new Date(item.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'short' }) : 'Today'}
                    </div>
                    
                    <div class="exam-news-title">
                      {item.title}
                    </div>
                    
                    <div class="exam-news-summary">
                      {item.summary && item.summary.length > 140 ? item.summary.slice(0, 140) + '...' : item.summary}
                    </div>
                    
                    <span class="news-topic">
                      {item.topic}
                    </span>
                    
                    <a href={`/current-affairs/${item.slug}`} class="read-more-link">
                      Read full analysis →
                    </a>
                  </div>
                )) : (
                  <p>No news available yet.</p>
                )}
              </div>
            </div>
            <div class="revision-streak">
              🔥 Revision Streak: 3 days
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Features -->
    <section class="features">
      <div class="container">
        <h2>Everything You Need</h2>
        <div class="features-grid">
          <a href="/notes" class="feature-card">
            <div class="feature-icon">📚</div>
            <h3>Study Notes</h3>
            <p>Concise, exam-focused notes covering all TNPSC subjects — History, Polity, Economy, Science, and Tamil.</p>
          </a>
          <a href="/syllabus" class="feature-card">
            <div class="feature-icon">📋</div>
            <h3>Syllabus</h3>
            <p>Complete Group II/IIA syllabus with unit-wise breakdown, topic lists, and linked study notes.</p>
          </a>
          <a href="/jobs" class="feature-card">
            <div class="feature-icon">💼</div>
            <h3>Job Alerts</h3>
            <p>Latest TN government job notifications, exam dates, and application deadlines — updated daily.</p>
          </a>
          <a href="/tnpsc" class="feature-card">
            <div class="feature-icon">🎯</div>
            <h3>TNPSC Guide</h3>
            <p>Everything about TNPSC — exam pattern, syllabus, group-wise eligibility, and preparation roadmap.</p>
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  /* Hero */
  .hero {
    background: linear-gradient(160deg, #fff 0%, var(--bg) 100%);
    border-bottom: 1px solid var(--border);
    padding: 4.5rem 0 3.5rem;
  }
  .hero-container {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 40px;
    align-items: start;
  }

  /* Left */
  .hero-left { max-width: 500px; }
  .badge {
    display: inline-block;
    background: #fff0f0;
    color: var(--accent);
    border: 1px solid #ffc8c8;
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 1.25rem;
  }
  .hero-title {
    font-size: 64px;
    font-weight: 700;
    line-height: 1.1;
    color: var(--navy);
    margin: 0;
  }
  .hero-subtitle {
    font-size: 18px;
    color: #556070;
    margin-top: 16px;
    max-width: 520px;
    line-height: 1.6;
  }
  .hero-buttons { 
    margin-top: 28px; 
    display: flex; 
    gap: 14px; 
    margin-bottom: 2.5rem; 
  }
  .btn-primary {
    background: var(--accent); color: #fff;
    padding: 0.75rem 1.75rem; border-radius: 8px;
    font-weight: 700; font-size: 0.95rem;
    transition: opacity 0.15s, transform 0.15s;
  }
  .btn-primary:hover { opacity: 0.88; transform: translateY(-1px); background: #b9141b; }
  .btn-outline {
    background: transparent; color: var(--navy);
    padding: 0.75rem 1.75rem; border-radius: 8px;
    font-weight: 600; font-size: 0.95rem;
    border: 1.5px solid var(--border);
    transition: border-color 0.15s, transform 0.15s;
  }
  .btn-outline:hover { border-color: var(--navy); transform: translateY(-1px); }
  .hero-stats { display: flex; gap: 2.5rem; }
  .stat span {
    font-family: 'Playfair Display', serif;
    font-size: 1.8rem; font-weight: 700;
    color: var(--accent); display: block;
  }
  .stat p { color: var(--muted); font-size: 0.85rem; margin-top: 0.15rem; }

  /* News Panel */
  .news-right-col {
    display: flex; 
    flex-direction: column; 
    gap: 12px;
  }
  .exam-news-card {
    background: #1f355e;
    color: white;
    border-radius: 14px;
    padding: 20px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    transition: transform 0.2s ease;
    max-height: 280px;
    overflow-y: auto;
  }
  .exam-news-card:hover {
    transform: translateY(-2px);
  }
  .exam-news-card::-webkit-scrollbar { width: 6px; }
  .exam-news-card::-webkit-scrollbar-thumb { background: #8ea0c3; border-radius: 10px; }

  .news-panel-header {
    margin-bottom: 16px; 
    border-bottom: 1px solid rgba(255,255,255,0.1); 
    padding-bottom: 12px;
  }
  .news-panel-header h3 {
    margin: 0; font-size: 16px; font-weight: 700; display: flex; align-items: center; color: #fff;
  }

  .news-live-dot {
    width: 8px;
    height: 8px;
    background: #00d26a;
    border-radius: 50%;
    display: inline-block;
    margin-right: 8px;
    box-shadow: 0 0 0 0 rgba(0, 210, 106, 0.4);
    animation: livepulse 1.8s infinite;
  }
  @keyframes livepulse {
    0% { box-shadow: 0 0 0 0 rgba(0, 210, 106, 0.5); }
    70% { box-shadow: 0 0 0 6px rgba(0, 210, 106, 0); }
    100% { box-shadow: 0 0 0 0 rgba(0, 210, 106, 0); }
  }

  /* News item */
  .exam-news-item { 
    margin-bottom: 16px; 
    border-bottom: 1px solid rgba(255,255,255,0.08); 
    padding-bottom: 16px; 
  }
  .exam-news-item:last-child { border-bottom: none; margin-bottom: 0; padding-bottom: 0; }

  .exam-news-meta { 
    font-size: 11px; 
    opacity: 0.7; 
    margin-bottom: 6px; 
    text-transform: uppercase; 
    letter-spacing: 0.05em; 
    font-weight: 700;
  }

  .exam-news-title { 
    font-weight: 600; 
    font-size: 15px; 
    line-height: 1.4; 
    word-wrap: break-word; 
    margin: 4px 0 8px; 
  }
  
  .exam-news-summary { 
    font-size: 13px; 
    color: #d0d7e5; 
    margin-bottom: 8px; 
    line-height: 1.5;
  }
  
  .news-topic {
    display: inline-block;
    background: #e8eefc;
    color: #1f355e;
    padding: 4px 8px;
    border-radius: 6px;
    font-size: 11px;
    margin-top: 6px;
    font-weight: 700;
  }

  .read-more-link {
    display: block;
    color: #8faadb;
    font-size: 13px;
    font-weight: 600;
    text-decoration: none;
    margin-top: 10px;
    transition: color 0.15s;
  }
  .read-more-link:hover { color: #fff; text-decoration: underline; }

  .revision-streak {
    margin-top: 6px;
    text-align: center;
    font-size: 13px;
    font-weight: 700;
    color: #c1121f;
    background: #fff0f0;
    padding: 10px;
    border-radius: 12px;
    border: 1px solid #ffc8c8;
    box-shadow: 0 4px 12px rgba(193, 18, 31, 0.05);
  }

  /* Features */
  .features { padding: 5rem 0; margin-top: 80px; }
  .features h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem; color: var(--navy); margin-bottom: 2.5rem;
  }
  .features-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 1.25rem;
  }
  .feature-card {
    background: var(--surface); border: 1px solid var(--border);
    border-radius: var(--radius); padding: 2rem 1.5rem;
    transition: box-shadow 0.2s, transform 0.2s, border-color 0.2s;
    text-decoration: none; color: inherit; display: block;
  }
  .feature-card:hover {
    box-shadow: 0 8px 30px rgba(0,0,0,0.08);
    transform: translateY(-3px); border-color: #ffc8c8;
  }
  .feature-icon { font-size: 2rem; margin-bottom: 1rem; }
  .feature-card h3 { font-size: 1.1rem; color: var(--navy); margin-bottom: 0.6rem; }
  .feature-card p { font-size: 0.88rem; color: var(--muted); line-height: 1.65; }

  /* Responsive */
  @media (max-width: 900px) {
    .hero-container { grid-template-columns: 1fr; gap: 2rem; }
  }
  @media (max-width: 600px) {
    .hero-stats { gap: 1.5rem; }
    .features-grid { grid-template-columns: 1fr 1fr; }
    .hero-title { font-size: 42px; }
  }
</style>
