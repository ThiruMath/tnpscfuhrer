---
import Layout from '../layouts/Layout.astro';

// TNPSC Exam Calendar Data - upcoming exams
const upcomingExams = [
  {
    name: 'Group II / IIA (CSSE-II)',
    date: '2026-07-12',
    status: 'Confirmed',
    posts: 'Combined Civil Services Examination - II',
    vacancies: '6,318',
    color: '#C1121F'
  },
  {
    name: 'Group IV (CSSE-IV)',
    date: '2026-09-21',
    status: 'Tentative',
    posts: 'VAO, Junior Assistant, Typist',
    vacancies: '9,351',
    color: '#1a73e8'
  },
  {
    name: 'Group I Prelims',
    date: '2026-11-15',
    status: 'Tentative',
    posts: 'Deputy Collector, DSP, Assistant Commissioner',
    vacancies: '92',
    color: '#e37400'
  },
];

// Calculate days remaining
function daysUntil(dateStr: string): number {
  const target = new Date(dateStr);
  const today = new Date();
  const diff = target.getTime() - today.getTime();
  return Math.max(0, Math.ceil(diff / (1000 * 60 * 60 * 24)));
}
---

<Layout title="TNPSC Fuhrer – Exam Calendar, PYQ Practice & Study Notes" active="Home">
  <main>
    <!-- ─── Hero ──────────────────────────────────────────────────────── -->
    <section class="hero">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-left">
            <span class="hero-badge">🎯 Your TNPSC Exam Companion</span>
            <h1 class="hero-title">Plan. Practice.<br/><span class="highlight">Crack TNPSC.</span></h1>
            <p class="hero-subtitle">Exam calendar with study planner, previous year question practice with analytics, and comprehensive study notes — all in one place.</p>
            <div class="hero-ctas">
              <a href="/calendar" class="btn-primary">📅 Exam Calendar</a>
              <a href="/pyq" class="btn-outline">📝 Take PYQ Quiz</a>
            </div>
          </div>

          <!-- Countdown Card -->
          <div class="countdown-panel">
            <div class="countdown-header">
              <span class="countdown-live"></span>
              <span>Next Exam</span>
            </div>
            <h3 class="countdown-exam">{upcomingExams[0].name}</h3>
            <div class="countdown-grid">
              <div class="cd-unit">
                <span class="cd-val" id="cd-days">{daysUntil(upcomingExams[0].date)}</span>
                <span class="cd-label">Days</span>
              </div>
              <div class="cd-sep">:</div>
              <div class="cd-unit">
                <span class="cd-val" id="cd-hours">00</span>
                <span class="cd-label">Hours</span>
              </div>
              <div class="cd-sep">:</div>
              <div class="cd-unit">
                <span class="cd-val" id="cd-mins">00</span>
                <span class="cd-label">Mins</span>
              </div>
            </div>
            <div class="countdown-meta">
              <span>{upcomingExams[0].vacancies} vacancies</span>
              <span class={`status-chip ${upcomingExams[0].status.toLowerCase()}`}>{upcomingExams[0].status}</span>
            </div>
            <a href="/calendar" class="cd-link">View all exams →</a>
          </div>
        </div>
      </div>
    </section>

    <!-- ─── Upcoming Exams Strip ──────────────────────────────────────── -->
    <section class="exam-strip">
      <div class="container">
        <div class="strip-grid">
          {upcomingExams.map(exam => (
            <a href="/calendar" class="strip-card" style={`--card-accent: ${exam.color}`}>
              <div class="strip-top">
                <span class="strip-days">{daysUntil(exam.date)}<small>days</small></span>
                <span class={`strip-status ${exam.status.toLowerCase()}`}>{exam.status}</span>
              </div>
              <h4 class="strip-name">{exam.name}</h4>
              <p class="strip-info">{exam.posts}</p>
              <p class="strip-date">{new Date(exam.date).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' })}</p>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- ─── Core Features ─────────────────────────────────────────────── -->
    <section class="features">
      <div class="container">
        <h2 class="section-title">Everything You Need to Crack TNPSC</h2>
        <div class="features-grid">

          <a href="/calendar" class="fcard fcard-calendar">
            <div class="fcard-icon">📅</div>
            <h3>Exam Calendar & Study Planner</h3>
            <p>Track all TNPSC exam dates with a customizable study planner. Set daily goals, track progress, and never miss a deadline.</p>
            <span class="fcard-tag">NEW</span>
            <span class="fcard-arrow">→</span>
          </a>

          <a href="/pyq" class="fcard fcard-pyq">
            <div class="fcard-icon">📝</div>
            <h3>PYQ Practice & Analysis</h3>
            <p>Practice real TNPSC questions from previous years. Get instant results with subject-wise analysis and track your improvement.</p>
            <span class="fcard-tag">POPULAR</span>
            <span class="fcard-arrow">→</span>
          </a>

          <a href="/notes" class="fcard fcard-notes">
            <div class="fcard-icon">📚</div>
            <h3>Study Notes</h3>
            <p>Concise, exam-focused notes covering History, Polity, Economy, Science, Geography, and Tamil — 900+ topics.</p>
            <span class="fcard-arrow">→</span>
          </a>

          <a href="/syllabus" class="fcard fcard-syllabus">
            <div class="fcard-icon">📋</div>
            <h3>Syllabus Tracker</h3>
            <p>Complete Group II/IIA syllabus with unit-wise breakdown. Track what you've covered and what's remaining.</p>
            <span class="fcard-arrow">→</span>
          </a>

        </div>
      </div>
    </section>

    <!-- ─── Quick Stats ───────────────────────────────────────────────── -->
    <section class="quick-stats">
      <div class="container">
        <div class="stats-grid">
          <div class="stat-item">
            <span class="stat-num">900+</span>
            <span class="stat-desc">Study Notes</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">120+</span>
            <span class="stat-desc">PYQ Questions</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">Free</span>
            <span class="stat-desc">Forever</span>
          </div>
          <div class="stat-item">
            <span class="stat-num">24/7</span>
            <span class="stat-desc">Available</span>
          </div>
        </div>
      </div>
    </section>

  </main>
</Layout>

<script>
  // Live countdown timer
  const targetDate = new Date('2026-07-12T10:00:00+05:30');
  function updateCountdown() {
    const now = new Date();
    const diff = targetDate.getTime() - now.getTime();
    if (diff <= 0) return;
    const days = Math.floor(diff / (1000 * 60 * 60 * 24));
    const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
    const mins = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
    const dEl = document.getElementById('cd-days');
    const hEl = document.getElementById('cd-hours');
    const mEl = document.getElementById('cd-mins');
    if (dEl) dEl.textContent = days.toString();
    if (hEl) hEl.textContent = hours.toString().padStart(2, '0');
    if (mEl) mEl.textContent = mins.toString().padStart(2, '0');
  }
  updateCountdown();
  setInterval(updateCountdown, 60000);
</script>

<style>
  /* ─── Hero ──────────────────────────────────────────────────────── */
  .hero {
    background: linear-gradient(160deg, #fff 0%, var(--bg) 40%, #fff0f0 100%);
    padding: 5rem 0 3rem;
    border-bottom: 1px solid var(--border);
  }

  .hero-grid {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem;
    align-items: center;
  }

  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--accent-soft);
    color: var(--accent);
    border: 1px solid #ffc8c8;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    margin-bottom: 1.5rem;
    animation: fadeInUp 0.6s ease;
  }

  .hero-title {
    font-size: clamp(2.5rem, 5vw, 3.8rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--navy);
    margin: 0 0 1.25rem;
    animation: fadeInUp 0.6s ease 0.1s both;
  }

  .highlight {
    background: linear-gradient(135deg, var(--accent), #e85d68);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero-subtitle {
    font-size: 1.1rem;
    color: var(--muted);
    line-height: 1.7;
    max-width: 500px;
    margin-bottom: 2rem;
    animation: fadeInUp 0.6s ease 0.2s both;
  }

  .hero-ctas {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    animation: fadeInUp 0.6s ease 0.3s both;
  }

  /* ─── Countdown Panel ─────────────────────────────────────────────── */
  .countdown-panel {
    background: var(--navy);
    color: #fff;
    border-radius: 20px;
    padding: 2rem;
    box-shadow: 0 12px 40px rgba(20,33,61,0.25);
    animation: fadeInUp 0.6s ease 0.4s both;
    position: relative;
    overflow: hidden;
  }

  .countdown-panel::before {
    content: '';
    position: absolute;
    top: -50%;
    right: -30%;
    width: 200px;
    height: 200px;
    background: radial-gradient(circle, rgba(193,18,31,0.15) 0%, transparent 70%);
    border-radius: 50%;
  }

  .countdown-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.78rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(255,255,255,0.6);
    margin-bottom: 0.75rem;
  }

  .countdown-live {
    width: 8px;
    height: 8px;
    background: #34a853;
    border-radius: 50%;
    animation: pulse-glow-green 2s infinite;
  }

  @keyframes pulse-glow-green {
    0%, 100% { box-shadow: 0 0 0 0 rgba(52,168,83,0.4); }
    50% { box-shadow: 0 0 0 6px rgba(52,168,83,0); }
  }

  .countdown-exam {
    font-family: 'Inter', sans-serif;
    font-size: 1.3rem;
    font-weight: 700;
    margin-bottom: 1.5rem;
  }

  .countdown-grid {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .cd-unit { text-align: center; }
  .cd-val {
    display: block;
    font-size: 2.5rem;
    font-weight: 800;
    font-family: 'Inter', sans-serif;
    line-height: 1;
    background: linear-gradient(180deg, #fff, #c8d6f0);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .cd-label {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,0.5);
    font-weight: 600;
  }
  .cd-sep {
    font-size: 2rem;
    font-weight: 700;
    color: rgba(255,255,255,0.3);
    padding-bottom: 1rem;
  }

  .countdown-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.5);
    padding-top: 1rem;
    border-top: 1px solid rgba(255,255,255,0.1);
    margin-bottom: 1rem;
  }

  .status-chip {
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .status-chip.confirmed { background: rgba(52,168,83,0.2); color: #69db7c; }
  .status-chip.tentative { background: rgba(227,116,0,0.2); color: #ffa94d; }

  .cd-link {
    color: rgba(255,255,255,0.7);
    font-size: 0.85rem;
    font-weight: 600;
    transition: color 0.15s;
  }
  .cd-link:hover { color: #fff; }

  /* ─── Exam Strip ───────────────────────────────────────────────────── */
  .exam-strip {
    padding: 2.5rem 0;
    background: var(--surface);
    border-bottom: 1px solid var(--border);
  }

  .strip-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.25rem;
  }

  .strip-card {
    background: var(--bg);
    border: 1px solid var(--border);
    border-top: 4px solid var(--card-accent, var(--accent));
    border-radius: var(--radius);
    padding: 1.5rem;
    transition: all 0.2s ease;
    text-decoration: none;
    color: inherit;
  }
  .strip-card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-lg);
  }

  .strip-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 0.75rem;
  }

  .strip-days {
    font-size: 2rem;
    font-weight: 800;
    color: var(--card-accent, var(--accent));
    line-height: 1;
    font-family: 'Inter', sans-serif;
  }
  .strip-days small {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    display: block;
    color: var(--muted);
  }

  .strip-status {
    font-size: 0.68rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
  }
  .strip-status.confirmed { background: var(--green-soft); color: var(--green); }
  .strip-status.tentative { background: var(--amber-soft); color: var(--amber); }

  .strip-name {
    font-family: 'Inter', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 0.3rem;
  }

  .strip-info {
    font-size: 0.82rem;
    color: var(--muted);
    margin-bottom: 0.5rem;
  }

  .strip-date {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--card-accent, var(--accent));
  }

  /* ─── Features ──────────────────────────────────────────────────── */
  .features {
    padding: 5rem 0;
  }

  .section-title {
    font-size: clamp(1.5rem, 3vw, 2.2rem);
    color: var(--navy);
    margin-bottom: 2.5rem;
    text-align: center;
  }

  .features-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }

  .fcard {
    position: relative;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 2rem 2rem 2.5rem;
    transition: all 0.25s ease;
    text-decoration: none;
    color: inherit;
    overflow: hidden;
  }
  .fcard:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .fcard-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .fcard h3 {
    font-family: 'Inter', sans-serif;
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--navy);
    margin-bottom: 0.6rem;
  }

  .fcard p {
    font-size: 0.88rem;
    color: var(--muted);
    line-height: 1.65;
  }

  .fcard-tag {
    position: absolute;
    top: 1.25rem;
    right: 1.25rem;
    font-size: 0.65rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background: var(--accent);
    color: #fff;
  }

  .fcard-arrow {
    position: absolute;
    bottom: 1.5rem;
    right: 1.5rem;
    font-size: 1.2rem;
    color: var(--muted);
    transition: transform 0.2s;
  }
  .fcard:hover .fcard-arrow {
    transform: translateX(4px);
    color: var(--accent);
  }

  .fcard-calendar { border-top: 4px solid var(--accent); }
  .fcard-pyq { border-top: 4px solid var(--blue); }
  .fcard-pyq .fcard-tag { background: var(--blue); }
  .fcard-notes { border-top: 4px solid var(--green); }
  .fcard-syllabus { border-top: 4px solid var(--amber); }

  /* ─── Quick Stats ───────────────────────────────────────────────── */
  .quick-stats {
    padding: 3rem 0;
    background: var(--navy);
  }

  .stats-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 2rem;
    text-align: center;
  }

  .stat-num {
    display: block;
    font-family: 'Playfair Display', serif;
    font-size: 2.2rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.25rem;
  }

  .stat-desc {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.5);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  /* ─── Responsive ────────────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-grid { grid-template-columns: 1fr; gap: 2rem; }
    .strip-grid { grid-template-columns: 1fr; }
    .features-grid { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
  }

  @media (max-width: 600px) {
    .hero { padding: 3rem 0 2rem; }
    .hero-ctas { flex-direction: column; }
    .hero-ctas a { text-align: center; justify-content: center; }
  }
</style>
