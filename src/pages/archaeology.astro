---
import Layout from '../layouts/TamilLitLayout.astro';
---
<Layout title="Literature and Archaeology">
  <div class="tamil-lit-wrapper">
    <section class="hero">
      <div class="hero-content">
        <h1 class="hero-title"><span class="tamil-text">அகழாய்வு</span> Archaeology</h1>
        <p class="hero-subtitle">Material Evidence of the Sangam Age</p>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="prose">
          <p>The recent excavations at Keeladi, Adichanallur, and Korkai have fundamentally altered our understanding of the Sangam period, providing hard material evidence for the urban, literate society described in the poetry.</p>
        </div>
      </div>
    </section>
  </div>
</Layout>
