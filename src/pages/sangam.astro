---
import Layout from '../layouts/TamilLitLayout.astro';

const poems = [
  {
    id: 1,
    anthology: 'Kurunthokai',
    number: '2',
    tamil: 'யாயும் ஞாயும் யாரா கியரோ\nஏதலும் தானும் எந்நாள் காண்டும்\nதோணொடு வீழ்ந்த அனைத்தே.',
    translation: '"What could my mother be to yours? What kin is my father to yours anyway? And how did you and I meet ever? But in love our hearts have mingled as red earth and pouring rain."',
    poet: 'Cempulappeyanirar',
    theme: 'akam',
    themeLabel: 'Love (Akam)',
  },
  {
    id: 2,
    anthology: 'Purananuru',
    number: '192',
    tamil: 'யாதும் ஊரே யாவரும் கேளிர்\nதீதும் நன்றும் பிறர்தர வாரா\nநோதலும் தணிதலும் அவற்றோ ரன்ன\nசாதலும் புதுவது அன்றே.',
    translation: '"Every village is my own, every person is kin. Good and evil come not from others. Death itself is nothing new."',
    poet: 'Kaniyan Pungundranar',
    theme: 'puram',
    themeLabel: 'Philosophy (Puram)',
  },
  {
    id: 3,
    anthology: 'Akananuru',
    number: '149',
    tamil: 'நெஞ்சே நில்லாய் நில்லாய்\nமெல்லியல் முன்கை வெண்தோடு உடையாள்\nமணமனை வதுவை நாளை.',
    translation: '"Oh heart, stay still, stay still. Tomorrow is the wedding day of the girl with the white bangles on slender wrists."',
    poet: 'Unknown',
    theme: 'akam',
    themeLabel: 'Love (Akam)',
  },
];

const tinais = [
  { name: 'Kurinji', tamil: 'குறிஞ்சி', region: 'Mountains', theme: 'Union, meeting of lovers', color: '#3A6B3A', flower: 'Kurinji flower' },
  { name: 'Mullai', tamil: 'முல்லை', region: 'Forests', theme: 'Waiting, patient love', color: '#3A5B3A', flower: 'Jasmine' },
  { name: 'Marutam', tamil: 'மருதம்', region: 'Farmlands', theme: 'Infidelity, lovers\' quarrel', color: '#4A6B2A', flower: 'Marutam tree' },
  { name: 'Neytal', tamil: 'நெய்தல்', region: 'Seashore', theme: 'Longing, separation', color: '#2A4A6B', flower: 'Blue waterlily' },
  { name: 'Paalai', tamil: 'பாலை', region: 'Wasteland', theme: 'Separation, journey', color: '#6B4A2A', flower: 'Cactus flower' },
];
---
<Layout title="Sangam Literature" description="Explore the ancient Sangam poetry of Tamil Nadu — the oldest classical poetry in any language still spoken today.">

<section class="page-hero">
  <div class="page-hero-bg">
    <div class="ph-orb ph-orb--1"></div>
    <div class="ph-orb ph-orb--2"></div>
  </div>
  <div class="container page-hero-content">
    <p class="section-label">300 BCE – 300 CE</p>
    <h1 class="page-title">
      <span class="page-title-en">Sangam</span>
      <span class="page-title-ta">சங்க இலக்கியம்</span>
    </h1>
    <p class="page-intro">
      The earliest corpus of Tamil poetry, composed by hundreds of named poets across several centuries, preserved in eight anthologies and ten idylls. Remarkably modern in its sensibility — direct, secular, and profoundly human.
    </p>
  </div>
  <div class="page-scroll-hint">
    <div class="scroll-line"></div>
  </div>
</section>

<!-- OVERVIEW GRID -->
<section class="overview">
  <div class="container">
    <div class="overview-grid">
      <div class="overview-card">
        <span class="ov-num">8</span>
        <span class="ov-label">Major Anthologies</span>
        <p class="ov-detail">Ettuththokai — the Eight Anthologies — compiled from hundreds of independent poems.</p>
      </div>
      <div class="overview-card">
        <span class="ov-num">10</span>
        <span class="ov-label">Idylls</span>
        <p class="ov-detail">Pathupattu — longer narrative poems describing landscapes and royal courts.</p>
      </div>
      <div class="overview-card">
        <span class="ov-num">473+</span>
        <span class="ov-label">Named Poets</span>
        <p class="ov-detail">Including women poets like Avvaiyar, Nakkirar, and Kapilar — a remarkable diversity.</p>
      </div>
      <div class="overview-card">
        <span class="ov-num">5</span>
        <span class="ov-label">Landscape Themes (Tinais)</span>
        <p class="ov-detail">Each poem is set in a symbolic landscape that encodes its emotional theme.</p>
      </div>
    </div>
  </div>
</section>

<!-- TINAI SYSTEM -->
<section class="tinai-section">
  <div class="container">
    <p class="section-label">The Sangam Aesthetic System</p>
    <h2 class="section-title">The Five Tinais</h2>
    <p class="section-desc">Sangam poetry assigns each poem to a landscape called a tinai, which maps directly to an emotional theme. Mountains mean union; forests mean waiting; seashores mean longing. This system is unique in world literature.</p>

    <div class="tinai-grid">
      {tinais.map((t, i) => (
        <div class="tinai-card" style={`--tc: ${t.color}; animation-delay: ${i * 0.1}s`}>
          <div class="tinai-color-bar"></div>
          <div class="tinai-body">
            <h3 class="tinai-name">{t.name}</h3>
            <p class="tinai-tamil">{t.tamil}</p>
            <p class="tinai-region">{t.region}</p>
            <div class="tinai-divider"></div>
            <p class="tinai-theme">{t.theme}</p>
            <p class="tinai-flower">{t.flower}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- FEATURED POEMS -->
<section class="poems-section">
  <div class="container">
    <p class="section-label">Selected Verses</p>
    <h2 class="section-title">Sangam Poetry in English</h2>
    <p class="section-desc">These poems, over two thousand years old, speak of love, longing, and the human condition with startling freshness.</p>

    <div class="poems-list">
      {poems.map((poem, i) => (
        <article class="poem-card" style={`animation-delay: ${i * 0.12}s`}>
          <div class="poem-header">
            <div>
              <span class="poem-anthology">{poem.anthology}</span>
              <span class="poem-num">#{poem.number}</span>
            </div>
            <span class={`poem-theme poem-theme--${poem.theme}`}>{poem.themeLabel}</span>
          </div>
          <blockquote class="poem-tamil">{poem.tamil}</blockquote>
          <div class="poem-divider"></div>
          <p class="poem-translation">{poem.translation}</p>
          <p class="poem-poet">— {poem.poet}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<!-- THE ANTHOLOGIES -->
<section class="anthologies-section">
  <div class="container">
    <p class="section-label">The Canon</p>
    <h2 class="section-title">The Eight Anthologies</h2>
    <div class="anthologies-grid">
      {[
        { name: 'Natrinai', tamil: 'நற்றிணை', poems: '400', theme: 'All five tinais', mood: 'Refined love' },
        { name: 'Kurunthokai', tamil: 'குறுந்தொகை', poems: '401', theme: 'Love themes', mood: 'Intimate & tender' },
        { name: 'Ainkurunuru', tamil: 'ஐங்குறுநூறு', poems: '500', theme: 'Five tinais, 100 each', mood: 'Musical, patterned' },
        { name: 'Padirruppattu', tamil: 'பதிற்றுப்பத்து', poems: '80', theme: 'Puram (heroism)', mood: 'Regal & martial' },
        { name: 'Purananuru', tamil: 'புறநானூறு', poems: '400', theme: 'War & philosophy', mood: 'Bold & universal' },
        { name: 'Akananuru', tamil: 'அகநானூறு', poems: '400', theme: 'Akam (love)', mood: 'Lush & detailed' },
        { name: 'Kalittokai', tamil: 'கலித்தொகை', poems: '150', theme: 'Dramatic love', mood: 'Passionate dialogues' },
        { name: 'Paripatal', tamil: 'பரிபாடல்', poems: '70', theme: 'Devotion & city', mood: 'Grandeur & devotion' },
      ].map((a, i) => (
        <div class="anthology-card" style={`animation-delay: ${i * 0.07}s`}>
          <h3 class="anth-name">{a.name}</h3>
          <p class="anth-tamil">{a.tamil}</p>
          <p class="anth-poems"><strong>{a.poems}</strong> poems</p>
          <p class="anth-theme">{a.theme}</p>
          <p class="anth-mood">{a.mood}</p>
        </div>
      ))}
    </div>
  </div>
</section>

</Layout>

<style>
.page-hero {
  min-height: 70vh;
  display: flex;
  align-items: center;
  padding: 10rem 0 6rem;
  position: relative;
  overflow: hidden;
}

.page-hero-bg {
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 100% 80% at 30% 50%,
    rgba(92,15,15,0.4) 0%, rgba(15,10,6,0) 60%);
}

.ph-orb {
  position: absolute;
  border-radius: 50%;
  filter: blur(100px);
  pointer-events: none;
}
.ph-orb--1 {
  width: 700px; height: 400px;
  top: -100px; left: -200px;
  background: rgba(92,15,15,0.3);
  animation: float 9s ease-in-out infinite;
}
.ph-orb--2 {
  width: 400px; height: 400px;
  bottom: -100px; right: 10%;
  background: rgba(201,152,58,0.07);
  animation: float 12s ease-in-out infinite reverse;
}

.page-hero-content { position: relative; z-index: 1; }

.page-title {
  display: flex;
  flex-direction: column;
  margin-bottom: 1.5rem;
}

.page-title-en {
  font-family: var(--font-display);
  font-size: clamp(3rem, 10vw, 7rem);
  font-weight: 300;
  color: var(--parchment);
  line-height: 1;
  letter-spacing: -0.01em;
}

.page-title-ta {
  font-family: var(--font-tamil);
  font-size: clamp(1.5rem, 5vw, 3rem);
  color: var(--gold);
  font-weight: 300;
}

.page-intro {
  font-family: var(--font-body);
  font-size: 1.15rem;
  color: var(--parchment-dark);
  max-width: 65ch;
  line-height: 1.85;
}

.page-scroll-hint {
  position: absolute;
  bottom: 2rem; left: 50%;
  transform: translateX(-50%);
}

.scroll-line {
  width: 1px; height: 50px;
  background: linear-gradient(to bottom, rgba(201,152,58,0.4), transparent);
  animation: float 2s ease-in-out infinite;
}

/* OVERVIEW */
.overview {
  padding: 5rem 0;
  background: var(--ink-mid);
  border-top: 1px solid rgba(201,152,58,0.1);
  border-bottom: 1px solid rgba(201,152,58,0.1);
}

.overview-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  gap: 2px;
}

.overview-card {
  display: flex;
  flex-direction: column;
  padding: 2.5rem 2rem;
  background: rgba(15,10,6,0.4);
}

.ov-num {
  font-family: var(--font-display);
  font-size: 3rem;
  font-weight: 600;
  color: var(--gold);
  line-height: 1;
  margin-bottom: 0.25rem;
}

.ov-label {
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 500;
  color: var(--parchment);
  margin-bottom: 0.75rem;
  letter-spacing: 0.05em;
}

.ov-detail {
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--text-muted);
  line-height: 1.6;
}

/* TINAI */
.tinai-section { padding: 8rem 0; }

.tinai-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1px;
  margin-top: 3rem;
  border: 1px solid rgba(201,152,58,0.1);
}

.tinai-card {
  display: flex;
  flex-direction: column;
  background: rgba(15,10,6,0.4);
  overflow: hidden;
  transition: background 0.3s;
  animation: fadeUp 0.8s var(--ease-out) both;
}

.tinai-card:hover { background: rgba(42,31,21,0.7); }

.tinai-color-bar {
  height: 3px;
  background: var(--tc);
}

.tinai-body { padding: 2rem 1.5rem; }

.tinai-name {
  font-family: var(--font-display);
  font-size: 1.4rem;
  font-weight: 500;
  color: var(--parchment);
  margin-bottom: 0.2rem;
}

.tinai-tamil {
  font-family: var(--font-tamil);
  font-size: 1rem;
  color: var(--gold);
  margin-bottom: 0.4rem;
}

.tinai-region {
  font-family: var(--font-body);
  font-size: 0.85rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--text-faint);
  margin-bottom: 1rem;
}

.tinai-divider {
  height: 1px;
  background: rgba(201,152,58,0.15);
  margin-bottom: 1rem;
}

.tinai-theme {
  font-family: var(--font-body);
  font-style: italic;
  font-size: 1rem;
  color: var(--parchment-dark);
  margin-bottom: 0.5rem;
}

.tinai-flower {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--text-faint);
}

/* POEMS */
.poems-section {
  padding: 8rem 0;
  background: var(--ink-mid);
}

.poems-list {
  display: flex;
  flex-direction: column;
  gap: 2px;
  margin-top: 3rem;
}

.poem-card {
  background: rgba(15,10,6,0.5);
  padding: 3rem;
  border-left: 3px solid var(--crimson);
  animation: fadeUp 0.8s var(--ease-out) both;
  transition: background 0.3s;
}

.poem-card:hover { background: rgba(42,31,21,0.6); }

.poem-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 1.5rem;
}

.poem-anthology {
  font-family: var(--font-display);
  font-size: 0.85rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--text-faint);
  margin-right: 0.5rem;
}

.poem-num {
  font-family: var(--font-display);
  font-size: 0.85rem;
  color: var(--gold);
}

.poem-theme {
  font-family: var(--font-display);
  font-size: 0.75rem;
  letter-spacing: 0.1em;
  padding: 0.25rem 0.75rem;
  border-radius: 1px;
}

.poem-theme--akam {
  background: rgba(139,26,26,0.2);
  color: var(--crimson-light);
  border: 1px solid rgba(139,26,26,0.3);
}

.poem-theme--puram {
  background: rgba(58,107,58,0.2);
  color: #7BC47B;
  border: 1px solid rgba(58,107,58,0.3);
}

.poem-tamil {
  font-family: var(--font-tamil);
  font-size: 1.15rem;
  color: var(--gold-light);
  line-height: 2;
  margin-bottom: 1.5rem;
  white-space: pre-line;
}

.poem-divider {
  width: 3rem; height: 1px;
  background: rgba(201,152,58,0.2);
  margin-bottom: 1.5rem;
}

.poem-translation {
  font-family: var(--font-display);
  font-style: italic;
  font-size: 1.15rem;
  color: var(--parchment-dark);
  line-height: 1.7;
  max-width: 65ch;
  margin-bottom: 1rem;
}

.poem-poet {
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--text-faint);
}

/* ANTHOLOGIES */
.anthologies-section { padding: 8rem 0; }

.anthologies-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 1px;
  margin-top: 3rem;
  border: 1px solid rgba(201,152,58,0.1);
}

.anthology-card {
  padding: 2rem 1.5rem;
  background: rgba(15,10,6,0.3);
  transition: background 0.3s;
  animation: fadeUp 0.8s var(--ease-out) both;
  border-bottom: 1px solid rgba(201,152,58,0.06);
}

.anthology-card:hover { background: rgba(139,26,26,0.1); }

.anth-name {
  font-family: var(--font-display);
  font-size: 1.3rem;
  font-weight: 500;
  color: var(--parchment);
  margin-bottom: 0.2rem;
}

.anth-tamil {
  font-family: var(--font-tamil);
  font-size: 0.9rem;
  color: var(--gold);
  margin-bottom: 0.75rem;
}

.anth-poems {
  font-family: var(--font-body);
  font-size: 0.9rem;
  color: var(--text-muted);
  margin-bottom: 0.25rem;
}

.anth-poems strong { color: var(--parchment-dark); }

.anth-theme {
  font-family: var(--font-body);
  font-size: 0.85rem;
  color: var(--text-faint);
  margin-bottom: 0.25rem;
}

.anth-mood {
  font-family: var(--font-body);
  font-style: italic;
  font-size: 0.9rem;
  color: var(--crimson-light);
  margin-top: 0.5rem;
}

@media (max-width: 768px) {
  .page-hero { padding: 8rem 0 4rem; }
  .poems-section .container, .anthologies-section .container { padding: 0 1rem; }
  .poem-card { padding: 1.5rem; }
}
</style>
