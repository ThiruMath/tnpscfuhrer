---
import Layout from '../layouts/Layout.astro';

const subjects = [
  { icon: '🏛️', title: 'History', count: '80+ notes', desc: 'Ancient, Medieval & Modern Indian History, Tamil Nadu History, Freedom Movement.' },
  { icon: '⚖️', title: 'Polity', count: '60+ notes', desc: 'Indian Constitution, Governance, Parliament, State Administration.' },
  { icon: '🌍', title: 'Geography', count: '50+ notes', desc: 'Physical, Indian & Tamil Nadu Geography, Climate, Resources.' },
  { icon: '💰', title: 'Economics', count: '55+ notes', desc: 'Indian Economy, Five Year Plans, Banking, Inflation, Budget.' },
  { icon: '🔬', title: 'Science', count: '70+ notes', desc: 'Physics, Chemistry, Biology, Environment & Ecology.' },
  { icon: '🔤', title: 'Tamil', count: '40+ notes', desc: 'Tamil Literature, Grammar, Poets, Sangam Period, Modern Tamil.' },
  { icon: '📰', title: 'Current Affairs', count: 'Updated daily', desc: 'Monthly current affairs compiled specifically for TNPSC exams.' },
  { icon: '🧮', title: 'Aptitude', count: '30+ notes', desc: 'Maths, Reasoning & Mental Ability for TNPSC Paper II.' },
];
---

<Layout title="Notes" description="Free TNPSC study notes covering all subjects — History, Polity, Geography, Economics, Science, and Tamil." active="Notes">
  <main class="container">
    <div class="page-header">
      <span class="badge">Study Material</span>
      <h1>Study Notes</h1>
      <p>Concise, exam-focused notes covering every TNPSC subject. No fluff — just what matters for the exam.</p>
    </div>

    <div class="notes-grid">
      {subjects.map(s => (
        <div class="note-card card">
          <div class="note-icon">{s.icon}</div>
          <div>
            <div class="note-header">
              <h3>{s.title}</h3>
              <span class="count">{s.count}</span>
            </div>
            <p>{s.desc}</p>
          </div>
        </div>
      ))}
    </div>

    <div class="coming-soon">
      <p>📌 More notes added regularly. Bookmark this page or check back often.</p>
    </div>
  </main>
</Layout>

<style>
  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  .note-card {
    display: flex;
    gap: 1.25rem;
    align-items: flex-start;
  }

  .note-icon { font-size: 1.8rem; flex-shrink: 0; margin-top: 0.1rem; }

  .note-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .note-header h3 { font-size: 1rem; color: var(--navy); font-family: 'DM Sans', sans-serif; font-weight: 600; }
  .count { font-size: 0.75rem; color: var(--accent); font-weight: 600; background: var(--accent-soft); padding: 0.15rem 0.5rem; border-radius: 100px; white-space: nowrap; }

  .note-card p { font-size: 0.88rem; color: var(--muted); line-height: 1.65; }

  .coming-soon {
    margin-top: 2.5rem;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border: 1px dashed var(--border);
    border-radius: var(--radius);
    color: var(--muted);
    font-size: 0.9rem;
  }
</style>
