---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

// Define the type as an array of strings to fix the 'any[]' error
const notesDir = path.join(process.cwd(), 'public', 'notes');
let files: string[] = []; 

try {
  // We specify that the result of readdirSync is a string array
  files = fs.readdirSync(notesDir).filter((f: string) => f.endsWith('.md'));
} catch (e) {
  console.error("Folder not found:", e);
  files = [];
}
---

<Layout title="Notes Browser">
  <div class="notes-wrapper">
    <nav class="sidebar">
      <div class="nav-header">Browse</div>
      <button class="filter-btn active">All ({files.length})</button>
      <button class="filter-btn">Tamil & History</button>
      <button class="filter-btn">Polity</button>
      <button class="filter-btn">Maths</button>
    </nav>

    <main class="main-content">
      <div class="browser-header">
        <input type="text" id="noteSearch" placeholder="Search notes..." />
      </div>

      <div class="content-grid">
        <div class="notes-list-panel">
          <h3>All Notes</h3>
          <ul id="file-list">
            {files.map(file => (
              <li>
                <button class="note-link" data-filename={file}>
                  {file.replace('.md', '').replace(/_/g, ' ')}
                </button>
              </li>
            ))}
          </ul>
        </div>

        <div class="preview-panel">
          <div id="content-display">
            <div class="empty-state">
               <h3>Select a note to view content</h3>
               <p>Choose from the list on the left.</p>
            </div>
          </div>
        </div>
      </div>
    </main>
  </div>
</Layout>

<style>
  .notes-wrapper { display: flex; height: 100vh; background: #f8f9fa; }
  
  /* Sidebar styles matching your screenshot */
  .sidebar { width: 250px; background: white; border-right: 1px solid #eee; padding: 20px; }
  .filter-btn { display: block; width: 100%; text-align: left; padding: 10px; margin: 5px 0; border: none; background: none; cursor: pointer; border-radius: 8px; font-weight: 500; }
  .filter-btn.active { background: #1a1a1a; color: white; }

  /* Grid Layout */
  .main-content { flex: 1; display: flex; flex-direction: column; padding: 20px; }
  .content-grid { display: grid; grid-template-columns: 350px 1fr; gap: 20px; flex: 1; margin-top: 20px; overflow: hidden; }

  .notes-list-panel { background: white; border-radius: 12px; border: 1px solid #eee; overflow-y: auto; padding: 15px; }
  .preview-panel { background: white; border-radius: 12px; border: 1px solid #eee; padding: 30px; overflow-y: auto; }

  .note-link { width: 100%; text-align: left; padding: 12px; border: none; background: none; border-bottom: 1px solid #f0f0f0; cursor: pointer; }
  .note-link:hover { background: #fff5f5; color: #d32f2f; }
</style>