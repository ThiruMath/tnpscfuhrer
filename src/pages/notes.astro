const CATEGORIES = {
  "All Notes": ALL_FILES,
  "Tamil & History": ALL_FILES.filter(f => /tamil|tamilians|mgr|justice_party|ancient_tamil|modern_history_of_tamil|history_of_tn|contribution_of_tamil|19th_century|ancient_history|advent_of_european|brahmo|ishwar|debendranath|keshab|alexander_cunningham|james_prinsep|curzon|lord_curzon|hilton_young|jawaharlal|1936|development_of_rationalism/i.test(f)),
  "Polity & Governance": ALL_FILES.filter(f => /polity|president|parliament|governor|chief_minister|prime_minister|constitution|fundamental|directive|citizenship|preamble|emergency|amendment|article_|executive|lok_|law_making|district|local_self|central_govt|cabinet|pmo|commission|committee|administrative|finance_comm|parties|judgement|making_of|indian_government|group_2|g2|appointment|empowerment|ganga|panchsheel|national_security/i.test(f)),
  "Economics & Banking": ALL_FILES.filter(f => /bank|money|inflation|economic|planning|five_year|budget|gst|fiscal|monetary|national_income|poverty|liberali|privatisation|globaliz|barter|cashless|cryptocurrency|tax|price_theory|income_theory|capitalism|land_reform|plan_|niti|annual_plan|plan_holiday|bad_loan|coins|demand_and_supply|plastic_money|metallic_standard|papper_currency|central_bank_digital|non-banking|co-operative|classification_of_bank|banking_structure|banking_sector|merger_of_public/i.test(f)),
  "Data Science & AI": ALL_FILES.filter(f => /data|machine_learning|deep_learning|neural|algorithm|regression|classification|cluster|python|pandas|numpy|keras|nlp|generative|embedding|feature|gradient|logistic|decision_tree|naive_bayes|pca|lda|k-means|dbscan|gmm|hierarchical|overfitting|generalization|loss|accuracy|precision|recall|auc|confusion|encoding|normalization|outlier|noise|binning|pipeline|jupyter|matplotlib|big_data|hadoop|cloud|ocr|ascii|artificial|adversarial|beautiful_soup|downsampling|imbalanced|hyperparameter|labels|feedback_loop|prediction_bias|model|generative_ai/i.test(f)),
  "Mathematics": ALL_FILES.filter(f => /math|geometry|circle|fraction|percentage|hcf|lcm|binomial|polynomial|coordinate|mensuration|probability|statistic|mean|median|mode|distribution|set_theory|metric_space|irrational|integer|number|ncert|area|volume|lines_and|addition|multiplication|bayes|discrete|coefficient|dispersion|variance|deviation|class_6|mathi|latex|bounded|countable|independent_events|normal_distribution|log_scaling|linear_scaling|carl_fredrich|gottfried|henri_poincare|mathematician/i.test(f)),
  "Cybersecurity": ALL_FILES.filter(f => /cyber|malware|phishing|password|attack|intrusion|antivirus|network_protocol|playbook|cryptograph|glossary_of_cyber|free_cyber|physical_attack/i.test(f)),
  "Current Affairs": ALL_FILES.filter(f => /^jan$|^feb$|^march$|^april$|jan_14|jan_ca|feb_ca|april_ca|daily_news|national_events|international/i.test(f)),
};

let currentCat = "All Notes";
let currentView = "browse";
let currentNote = null;
let bookmarks = [];
let recent = [];

try { bookmarks = JSON.parse(localStorage.getItem('tnpsc_bookmarks') || '[]'); } catch(e){}
try { recent = JSON.parse(localStorage.getItem('tnpsc_recent') || '[]'); } catch(e){}

function fmt(name) {
  return name.replace(/_/g,' ').replace(/-/g,' - ').replace(/\s+/g,' ').trim();
}

function getPool() {
  if (currentView === 'bookmarks') return bookmarks;
  if (currentView === 'recent') return recent;
  return CATEGORIES[currentCat] || ALL_FILES;
}

function renderList() {
  const search = (document.getElementById('searchInput').value || '').toLowerCase();
  const pool = getPool();
  const filtered = pool.filter(f => !search || fmt(f).toLowerCase().includes(search));

  document.getElementById('listTitle').textContent =
    currentView === 'bookmarks' ? 'Saved Notes' : currentView === 'recent' ? 'Recent Notes' : currentCat;
  document.getElementById('listCount').textContent = filtered.length + ' notes';

  const list = document.getElementById('notesList');
  if (!filtered.length) {
    list.innerHTML = '<div class="no-results">No notes found.</div>';
    return;
  }
  list.innerHTML = filtered.map(f => `
    <div class="note-item ${currentNote===f?'active':''}" onclick="openNote('${f.replace(/'/g,"\\'")}')">
      <span>${fmt(f)}</span>
      ${bookmarks.includes(f) ? '<span class="bm-star">⭐</span>' : ''}
    </div>
  `).join('');
}

function switchCat(cat, btn) {
  currentCat = cat;
  document.querySelectorAll('.cat-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderList();
}

function switchView(view, btn) {
  currentView = view;
  document.querySelectorAll('.view-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderList();
}

function toggleBookmark(filename) {
  bookmarks = bookmarks.includes(filename)
    ? bookmarks.filter(b => b !== filename)
    : [...bookmarks, filename];
  try { localStorage.setItem('tnpsc_bookmarks', JSON.stringify(bookmarks)); } catch(e){}
  renderList();
  const btn = document.getElementById('bmBtn');
  if (btn) {
    const saved = bookmarks.includes(filename);
    btn.textContent = saved ? '⭐ Saved' : '☆ Save';
    btn.className = 'btn-bm' + (saved ? ' saved' : '');
  }
}

function renderMD(text) {
  return text
    .replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;')
    .replace(/^#### (.+)$/gm,'<h4>$1</h4>')
    .replace(/^### (.+)$/gm,'<h3>$1</h3>')
    .replace(/^## (.+)$/gm,'<h2>$1</h2>')
    .replace(/^# (.+)$/gm,'<h1>$1</h1>')
    .replace(/\*\*(.+?)\*\*/g,'<strong>$1</strong>')
    .replace(/\*(.+?)\*/g,'<em>$1</em>')
    .replace(/`([^`]+)`/g,'<code>$1</code>')
    .replace(/^\s*[-*] (.+)$/gm,'<li>$1</li>')
    .replace(/^\s*\d+\. (.+)$/gm,'<li>$1</li>')
    .replace(/(<li>[\s\S]*?<\/li>)/g,'<ul>$1</ul>')
    .replace(/\n\n+/g,'</p><p>');
}

async function openNote(filename) {
  currentNote = filename;
  recent = [filename, ...recent.filter(r => r !== filename)].slice(0, 20);
  try { localStorage.setItem('tnpsc_recent', JSON.stringify(recent)); } catch(e){}
  renderList();

  const isBm = bookmarks.includes(filename);
  const detail = document.getElementById('noteDetail');
  detail.innerHTML = `
    <div class="detail-header">
      <div>
        <h2>${fmt(filename)}</h2>
        <div class="fname">${filename}.md</div>
      </div>
      <button id="bmBtn" class="btn-bm ${isBm?'saved':''}" onclick="toggleBookmark('${filename.replace(/'/g,"\\'")}')">
        ${isBm ? '⭐ Saved' : '☆ Save'}
      </button>
    </div>
    <div class="detail-body">
      <div class="loading-wrap">
        <div class="spinner"></div>
        <p>Loading study notes...</p>
      </div>
    </div>
  `;
  detail.scrollTop = 0;

  try {
    const res = await fetch("https://api.anthropic.com/v1/messages", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({
        model: "claude-sonnet-4-20250514",
        max_tokens: 1000,
        system: "You are a TNPSC exam study assistant. Return well-structured markdown study notes. Use ## headers, bullet points, bold key terms. Be concise, accurate, and exam-focused.",
        messages: [{ role: "user", content: `TNPSC study notes for: "${fmt(filename)}"` }]
      })
    });
    const data = await res.json();
    const text = data.content?.map(c => c.text||'').join('\n') || 'No content available.';
    detail.querySelector('.detail-body').innerHTML = `<p>${renderMD(text)}</p>`;
  } catch(e) {
    detail.querySelector('.detail-body').innerHTML = `<p style="color:var(--muted)">Failed to load. Please try again.</p>`;
  }
}

renderList();
</script>
</body>
</html>
