---
// This goes at the top of src/pages/notes.astro
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

// This reads the public/notes folder during build time
const notesDirectory = path.join(process.cwd(), 'public', 'notes');
let files: string[] = [];

try {
  files = fs.readdirSync(notesDirectory).filter(file => file.endsWith('.md'));
} catch (e) {
  console.error("Could not find the public/notes folder!");
}
---

<Layout title="Notes Browser">
  <aside class="sidebar">
    <ul>
      {files.map(file => (
        <li>
          <button class="note-link" data-filename={file}>
            {file.replace('.md', '').replace(/_/g, ' ')}
          </button>
        </li>
      ))}
    </ul>
  </aside>
</Layout>