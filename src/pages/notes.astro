---
import Layout from '../layouts/Layout.astro';
import fs from 'node:fs';
import path from 'node:path';

const notesDir = path.join(process.cwd(), 'public', 'notes');
let files: string[] = [];
try {
  files = fs.readdirSync(notesDir).filter((f: string) => f.endsWith('.md'));
} catch (e) {
  files = [];
}
---

<Layout title="Notes Browser">
  <div class="app-container">
    <aside class="category-sidebar">
      <div class="brand">TNPSC Fuhrer</div>
      <nav>
        <button class="cat-btn active">All Notes</button>
        <button class="cat-btn">Polity</button>
        <button class="cat-btn">History</button>
        <button class="cat-btn">Tamil</button>
      </nav>
    </aside>

    <section class="file-browser">
      <div class="search-bar">
        <input type="text" id="noteSearch" placeholder="Search 300+ notes..." />
      </div>
      <ul class="file-list" id="fileList">
        {files.map(file => (
          <li>
            <button class="note-link" data-filename={file}>
              <span class="file-icon">📄</span>
              {file.replace('.md', '').replace(/_/g, ' ')}
            </button>
          </li>
        ))}
      </ul>
    </section>

    <main class="preview-area">
      <div id="content-display" class="markdown-body">
        <div class="placeholder">
          <img src="/favicon.svg" alt="" style="width: 50px; opacity: 0.2;" />
          <p>Select a note to start reading</p>
        </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  import { marked } from 'marked';

  const display = document.getElementById('content-display') as HTMLDivElement;
  const searchInput = document.getElementById('noteSearch') as HTMLInputElement;
  const fileButtons = document.querySelectorAll('.note-link') as NodeListOf<HTMLButtonElement>;

  // Function to load content
  fileButtons.forEach(button => {
    button.addEventListener('click', async () => {
      const fileName = button.getAttribute('data-filename');
      if (!fileName || !display) return;

      display.innerHTML = '<div class="loading">Loading note content...</div>';
      
      try {
        const response = await fetch(`/notes/${fileName}`);
        if (!response.ok) throw new Error("File not found");
        const text = await response.text();
        display.innerHTML = await marked.parse(text);
        
        // Remove active class from others and add to this one
        fileButtons.forEach(btn => btn.classList.remove('active-note'));
        button.classList.add('active-note');
      } catch (err) {
        display.innerHTML = '<div class="error">Could not load this note. Check if file exists in public/notes/</div>';
      }
    });
  });

  // Search Logic
  searchInput?.addEventListener('input', () => {
    const term = searchInput.value.toLowerCase();
    fileButtons.forEach(btn => {
      const text = btn.innerText.toLowerCase();
      (btn.parentElement as HTMLElement).style.display = text.includes(term) ? 'block' : 'none';
    });
  });
</script>

<style>
  /* Alignment Fix: The Container */
  .app-container {
    display: flex;
    height: 100vh;
    overflow: hidden;
    font-family: 'DM Sans', sans-serif;
  }

  /* Column 1: Categories */
  .category-sidebar {
    width: 200px;
    background: #14213D;
    color: white;
    padding: 20px;
  }
  .cat-btn { 
    display: block; width: 100%; text-align: left; background: none; border: none; 
    color: #8a99af; padding: 10px; cursor: pointer; border-radius: 5px;
  }
  .cat-btn.active { color: white; background: #ffffff10; }

  /* Column 2: List */
  .file-browser {
    width: 350px;
    border-right: 1px solid #e8e5df;
    display: flex;
    flex-direction: column;
    background: #fff;
  }
  .search-bar { padding: 15px; border-bottom: 1px solid #eee; }
  #noteSearch { width: 100%; padding: 10px; border: 1px solid #ddd; border-radius: 8px; }
  .file-list { flex: 1; overflow-y: auto; list-style: none; padding: 0; margin: 0; }
  .note-link { 
    width: 100%; text-align: left; padding: 15px; border: none; background: none; 
    border-bottom: 1px solid #f9f9f9; cursor: pointer; transition: 0.2s;
  }
  .note-link:hover { background: #f0f7ff; }
  .active-note { background: #e6f0ff !important; border-left: 4px solid #c1121f; }

  /* Column 3: Preview */
  .preview-area {
    flex: 1;
    overflow-y: auto;
    background: #f8f7f4;
    padding: 40px;
  }
  .markdown-body {
    max-width: 800px;
    margin: 0 auto;
    background: white;
    padding: 40px;
    border-radius: 12px;
    min-height: 100%;
    box-shadow: 0 4px 20px rgba(0,0,0,0.05);
  }
  .placeholder { text-align: center; margin-top: 100px; color: #aaa; }
</style>