<script>
// @ts-nocheck

const ALL_FILES = [
"Adam_Smith",
"Ancient_History",
"Polity",
"Machine_Learning",
"Probability",
"Inflation",
"Banking",
"GST"
];

const CATEGORIES = {
"All Notes": ALL_FILES,
"Economics": ALL_FILES.filter(f=>/bank|inflation|gst|money/i.test(f)),
"Polity": ALL_FILES.filter(f=>/polity|constitution|president/i.test(f)),
"Data Science": ALL_FILES.filter(f=>/machine|data/i.test(f)),
"Maths": ALL_FILES.filter(f=>/probability|math/i.test(f))
};

let currentCat = "All Notes";
let currentView = "browse";
let currentNote = null;

let bookmarks = JSON.parse(localStorage.getItem("tnpsc_bookmarks")||"[]");
let recent = JSON.parse(localStorage.getItem("tnpsc_recent")||"[]");

function fmt(name){
return name.replace(/_/g," ");
}

function getPool(){
if(currentView==="bookmarks") return bookmarks;
if(currentView==="recent") return recent;
return CATEGORIES[currentCat]||ALL_FILES;
}

function renderList(){

const search=document.getElementById("searchInput").value.toLowerCase();
const pool=getPool();

const filtered=pool.filter(f=>!search||fmt(f).toLowerCase().includes(search));

document.getElementById("listCount").textContent=filtered.length+" notes";

const list=document.getElementById("notesList");

if(!filtered.length){
list.innerHTML="<div class='no-results'>No notes found</div>";
return;
}

list.innerHTML=filtered.map(f=>`
<div class="note-item ${currentNote===f?'active':''}" onclick="openNote('${f}')">
<span>${fmt(f)}</span>
${bookmarks.includes(f)?"⭐":""}
</div>
`).join("");

}

function switchCat(cat,btn){
currentCat=cat;
document.querySelectorAll(".cat-tab").forEach(b=>b.classList.remove("active"));
btn.classList.add("active");
renderList();
}

function switchView(view,btn){
currentView=view;
document.querySelectorAll(".view-tab").forEach(b=>b.classList.remove("active"));
btn.classList.add("active");
renderList();
}

function toggleBookmark(name){

if(bookmarks.includes(name))
bookmarks=bookmarks.filter(b=>b!==name);
else
bookmarks.push(name);

localStorage.setItem("tnpsc_bookmarks",JSON.stringify(bookmarks));
renderList();

}

function renderMD(md){

return md
.replace(/^### (.*$)/gim,"<h3>$1</h3>")
.replace(/^## (.*$)/gim,"<h2>$1</h2>")
.replace(/^# (.*$)/gim,"<h1>$1</h1>")
.replace(/\*\*(.*?)\*\*/gim,"<b>$1</b>")
.replace(/\*(.*?)\*/gim,"<i>$1</i>")
.replace(/\n/g,"<br>");

}

async function openNote(filename){

currentNote=filename;

recent=[filename,...recent.filter(r=>r!==filename)].slice(0,20);
localStorage.setItem("tnpsc_recent",JSON.stringify(recent));

renderList();

const detail=document.getElementById("noteDetail");

detail.innerHTML=`
<div class="loading-wrap">
<div class="spinner"></div>
<p>Loading notes...</p>
</div>
`;

try{

const res=await fetch("/notes/"+filename+".md");

if(!res.ok) throw new Error();

const md=await res.text();

detail.innerHTML=`
<div class="detail-header">
<h2>${fmt(filename)}</h2>
<button onclick="toggleBookmark('${filename}')">
${bookmarks.includes(filename)?"⭐ Saved":"☆ Save"}
</button>
</div>

<div class="detail-body">
${renderMD(md)}
</div>
`;

}catch{

detail.innerHTML="<p style='padding:20px'>Note not found</p>";

}

}

renderList();

</script>