---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNotes = await getCollection('notes');

// Group notes by subject category
const categoryMap: Record<string, { icon: string; color: string; desc: string }> = {
  'History':        { icon: '🏛️', color: '#C1121F', desc: 'Ancient, Medieval, Modern & Tamil History' },
  'Polity':         { icon: '⚖️', color: '#14213D', desc: 'Constitution, Rights, Parliament & Judiciary' },
  'Economy':        { icon: '📊', color: '#0a6e4f', desc: 'Indian Economy, Banking, Planning & GST' },
  'Geography':      { icon: '🌍', color: '#0369a1', desc: 'Physical, Human & Tamil Nadu Geography' },
  'Science':        { icon: '🔬', color: '#7c3aed', desc: 'Physics, Chemistry, Biology & Environment' },
  'Tamil':          { icon: '📜', color: '#be185d', desc: 'Tamil Literature, Grammar & Scholars' },
  'Current Affairs':{ icon: '📰', color: '#d97706', desc: 'Monthly Current Affairs & News Updates' },
  'Aptitude':       { icon: '🧮', color: '#0891b2', desc: 'Maths, Reasoning & Mental Ability' },
  'Other':          { icon: '📁', color: '#6b7280', desc: 'General Knowledge & Miscellaneous' },
};

// Sort notes newest first
const sortedNotes = [...allNotes].sort((a, b) => {
  const dateA = a.data.last_updated ? new Date(a.data.last_updated).getTime() : 0;
  const dateB = b.data.last_updated ? new Date(b.data.last_updated).getTime() : 0;
  return dateB - dateA;
});

// Categorize each note
function getCategory(note: any): string {
  if (note.data.subject) return note.data.subject;
  const slug = note.slug.toLowerCase();
  const body = (note.body || '').toLowerCase().slice(0, 300);
  const combined = slug + ' ' + body;
  if (/history|ancient|medieval|mughal|sangam|chola|pallav|vijayanagar|freedom|national movement|revolt/.test(combined)) return 'History';
  if (/polity|constitution|parliament|fundamental|judiciary|election|governor|president|lokpal/.test(combined)) return 'Polity';
  if (/economy|bank|gdp|planning|fiscal|monetary|rbi|gst|inflation|poverty|budget|revenue|tax/.test(combined)) return 'Economy';
  if (/geography|monsoon|river|soil|climate|rainfall|forest|wildlife|district/.test(combined)) return 'Geography';
  if (/science|physics|chemistry|biology|ecology|genetics|laser|nuclear|nutrition/.test(combined)) return 'Science';
  if (/tamil|இலக்கணம்|குறள்|சங்க|பாரதி|தமிழ்|grammar|literature|kavimani/.test(combined)) return 'Tamil';
  if (/current affairs|ca\.|jan|feb|mar|apr|may|jun|jul|aug|sep|oct|nov|dec/.test(combined)) return 'Current Affairs';
  if (/aptitude|simplification|hcf|lcm|percentage|ratio|profit|loss|reasoning|puzzle/.test(combined)) return 'Aptitude';
  return 'Other';
}

// Build category buckets
const categories: Record<string, any[]> = {};
for (const note of sortedNotes) {
  const cat = getCategory(note);
  if (!categories[cat]) categories[cat] = [];
  categories[cat].push(note);
}

// Order categories nicely
const catOrder = ['History','Polity','Economy','Geography','Science','Tamil','Current Affairs','Aptitude','Other'];
const orderedCats = catOrder.filter(c => categories[c]?.length > 0);

// Stats
const totalNotes = allNotes.length;
const uniqueSubjects = orderedCats.length;
---

<Layout title="Study Notes Library – TNPSC Fuhrer" description="Structured study notes for TNPSC Group II/IIA, covering History, Polity, Economy, Geography, Science and Tamil in an easy searchable format." active="Notes">
  <main>
    <!-- Hero Banner -->
    <div class="notes-hero">
      <div class="container">
        <div class="hero-badge">
          <span class="badge-dot"></span>
          {totalNotes}+ Notes Available
        </div>
        <h1>Study Notes Library</h1>
        <p class="hero-sub">Structured, exam-ready notes for TNPSC Group II/IIA — organized by subject for faster revision.</p>
        <div class="hero-stats">
          <div class="stat-pill">
            <span class="stat-num">{totalNotes}</span>
            <span class="stat-label">Total Notes</span>
          </div>
          <div class="stat-pill">
            <span class="stat-num">{uniqueSubjects}</span>
            <span class="stat-label">Subjects</span>
          </div>
          <div class="stat-pill">
            <span class="stat-num">Free</span>
            <span class="stat-label">Forever</span>
          </div>
        </div>
      </div>
    </div>

    <div class="container notes-body">
      <!-- Search + Filter Bar -->
      <div class="search-filter-bar">
        <div class="search-wrap">
          <svg class="search-icon" viewBox="0 0 20 20" fill="none"><circle cx="9" cy="9" r="6" stroke="currentColor" stroke-width="1.5"/><path d="M15 15l-3-3" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
          <input type="text" id="searchInput" placeholder="Search notes by topic, title…" autocomplete="off" />
          <button id="clearSearch" class="clear-btn" aria-label="Clear">✕</button>
        </div>
        <div class="cat-filters">
          <button class="cat-btn active" data-cat="all">All</button>
          {orderedCats.map(cat => (
            <button class="cat-btn" data-cat={cat} style={`--cc:${categoryMap[cat]?.color || '#6b7280'}`}>
              {categoryMap[cat]?.icon} {cat}
              <span class="cat-count">{categories[cat].length}</span>
            </button>
          ))}
        </div>
      </div>

      <!-- Results counter -->
      <div class="results-bar">
        <span id="resultsCount">{totalNotes} notes</span>
        <span class="results-hint">Click any note to read →</span>
      </div>

      <!-- Notes by Category -->
      <div id="notesContainer">
        {orderedCats.map(cat => {
          const meta = categoryMap[cat] || { icon: '📁', color: '#6b7280', desc: '' };
          return (
          <section class="cat-section" data-category={cat} id={`cat-${cat.toLowerCase().replace(/\s/g,'-')}`}>
            <div class="cat-header" style={`--cc:${meta.color}`}>
              <span class="cat-icon">{meta.icon}</span>
              <div>
                <h2>{cat}</h2>
                <p>{meta.desc}</p>
              </div>
              <div class="cat-badge">{categories[cat].length} notes</div>
            </div>

            <div class="notes-grid">
              {categories[cat].map(note => {
                const title = note.data.title || note.slug.replace(/[-_]/g, ' ').replace(/\.md$/, '');
                const tags: string[] = note.data.topics || note.data.tags || [];
                const date = note.data.last_updated
                  ? new Date(note.data.last_updated).toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' })
                  : '';
                const displayTitle = title.length > 60 ? title.slice(0, 60) + '…' : title;
                return (
                  <a
                    href={`/notes/${note.slug}`}
                    class="note-card"
                    data-title={title.toLowerCase()}
                    data-cat={cat}
                    style={`--nc:${meta.color}`}
                    data-topics={tags.join(',').toLowerCase()}
                  >
                    <div class="note-card-inner">
                      <div class="note-top">
                        <span class="note-cat-dot" style={`background:${meta.color}`}></span>
                        {date && <span class="note-date">{date}</span>}
                      </div>
                      <h3 class="note-title">{displayTitle}</h3>
                      {tags.length > 0 && (
                        <div class="note-tags">
                          {tags.slice(0, 3).map((tag: string) => (
                            <span class="note-tag">{tag}</span>
                          ))}
                          {tags.length > 3 && <span class="note-tag note-tag--more">+{tags.length - 3}</span>}
                        </div>
                      )}
                    </div>
                    <div class="note-arrow">→</div>
                  </a>
                );
              })}
            </div>
          </section>
          );
        })}

        <!-- No results -->
        <div id="noResults" class="no-results" style="display:none">
          <div class="no-results-icon">🔍</div>
          <h3>No notes found</h3>
          <p>Try a different search term or browse all categories.</p>
          <button onclick="clearSearch()" class="reset-btn">Clear search</button>
        </div>
      </div>
    </div>
  </main>
</Layout>

<script>
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const clearBtn = document.getElementById('clearSearch') as HTMLButtonElement;
  const resultsCount = document.getElementById('resultsCount')!;
  const catBtns = document.querySelectorAll('.cat-btn');
  const allSections = document.querySelectorAll('.cat-section') as NodeListOf<HTMLElement>;
  const noResults = document.getElementById('noResults')!;

  let activeCat = 'all';
  let searchQuery = '';

  function applyFilters() {
    let visible = 0;
    allSections.forEach(section => {
      const cat = section.dataset.category || '';
      const cards = section.querySelectorAll('.note-card') as NodeListOf<HTMLElement>;
      let sectionVisible = 0;

      const catMatch = activeCat === 'all' || cat === activeCat;

      cards.forEach(card => {
        const title = card.dataset.title || '';
        const topics = card.dataset.topics || '';
        const searchMatch = !searchQuery || title.includes(searchQuery) || topics.includes(searchQuery) || cat.toLowerCase().includes(searchQuery);
        const show = catMatch && searchMatch;
        card.style.display = show ? '' : 'none';
        if (show) { visible++; sectionVisible++; }
      });

      section.style.display = catMatch && sectionVisible > 0 ? '' : 'none';
    });

    resultsCount.textContent = `${visible} note${visible !== 1 ? 's' : ''}`;
    noResults.style.display = visible === 0 ? '' : 'none';
    clearBtn.style.display = searchQuery ? '' : 'none';
  }

  // Category buttons
  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      catBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      activeCat = (btn as HTMLElement).dataset.cat || 'all';
      applyFilters();
      if (activeCat !== 'all') {
        const target = document.getElementById(`cat-${activeCat.toLowerCase().replace(/\s/g,'-')}`);
        target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  });

  // Search
  searchInput.addEventListener('input', () => {
    searchQuery = searchInput.value.trim().toLowerCase();
    applyFilters();
  });

  clearBtn.addEventListener('click', () => {
    searchInput.value = '';
    searchQuery = '';
    applyFilters();
  });

  (window as any).clearSearch = () => {
    searchInput.value = '';
    searchQuery = '';
    catBtns.forEach(b => b.classList.remove('active'));
    catBtns[0].classList.add('active');
    activeCat = 'all';
    applyFilters();
  };

  applyFilters();
</script>

<style>
  /* Hero */
  .notes-hero {
    background: linear-gradient(135deg, #14213D 0%, #1d3461 60%, #C1121F22 100%);
    padding: 4rem 0 3rem;
    color: #fff;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .hero-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: rgba(255,255,255,0.1);
    border: 1px solid rgba(255,255,255,0.18);
    padding: 0.3rem 0.9rem;
    border-radius: 100px;
    font-size: 0.8rem;
    color: #e5e7eb;
    margin-bottom: 1.25rem;
    backdrop-filter: blur(8px);
  }
  .badge-dot {
    width: 6px; height: 6px;
    background: #22c55e;
    border-radius: 50%;
    animation: pulse 2s infinite;
  }
  @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  .notes-hero h1 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 4.5vw, 3.2rem);
    color: #fff;
    margin: 0 0 0.5rem;
  }
  .hero-sub { color: #9ca3af; font-size: 1.05rem; margin-bottom: 2rem; max-width: 560px; }
  .hero-stats { display: flex; gap: 1rem; flex-wrap: wrap; }
  .stat-pill {
    display: flex;
    flex-direction: column;
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 10px;
    padding: 0.75rem 1.5rem;
    min-width: 90px;
    backdrop-filter: blur(10px);
  }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }
  .stat-label { font-size: 0.75rem; color: #9ca3af; margin-top: 0.2rem; }

  /* Body */
  .notes-body { padding-top: 1.5rem; }

  /* Search + Filter */
  .search-filter-bar {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.25rem;
    padding: 1.25rem 1.5rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
    position: sticky;
    top: 64px;
    z-index: 50;
  }
  .search-wrap {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    background: var(--bg);
    border: 1.5px solid var(--border);
    border-radius: 8px;
    padding: 0 0.85rem;
    transition: border-color 0.2s;
  }
  .search-wrap:focus-within { border-color: var(--accent); }
  .search-icon { width: 16px; height: 16px; color: var(--muted); flex-shrink: 0; }
  #searchInput {
    flex: 1;
    padding: 0.7rem 0;
    border: none;
    background: transparent;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.95rem;
    color: var(--text);
    outline: none;
  }
  #searchInput::placeholder { color: var(--muted); }
  .clear-btn {
    border: none;
    background: none;
    color: var(--muted);
    cursor: pointer;
    font-size: 0.85rem;
    padding: 0.2rem;
    display: none;
    line-height: 1;
  }

  /* Category filter pills */
  .cat-filters {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .cat-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.38rem 0.9rem;
    border-radius: 100px;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    border: 1.5px solid var(--border);
    background: var(--surface);
    color: var(--muted);
    transition: all 0.2s;
    font-family: 'DM Sans', sans-serif;
    white-space: nowrap;
  }
  .cat-btn:hover { border-color: var(--cc, var(--accent)); color: var(--cc, var(--accent)); }
  .cat-btn.active { background: var(--cc, var(--accent)); color: #fff; border-color: var(--cc, var(--accent)); }
  .cat-count {
    background: rgba(255,255,255,0.25);
    border-radius: 100px;
    padding: 0 0.4rem;
    font-size: 0.72rem;
    line-height: 1.5;
  }
  .cat-btn:not(.active) .cat-count { background: var(--bg); color: var(--muted); }

  /* Results bar */
  .results-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
  #resultsCount { font-weight: 600; color: var(--text); }
  .results-hint { color: var(--muted); }

  /* Category Section */
  .cat-section { margin-bottom: 3.5rem; }
  .cat-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    background: linear-gradient(135deg, color-mix(in srgb, var(--cc) 8%, white), color-mix(in srgb, var(--cc) 2%, white));
    border: 1px solid color-mix(in srgb, var(--cc) 20%, var(--border));
    border-radius: 14px;
    padding: 1.25rem 1.75rem;
    margin-bottom: 1.25rem;
    position: relative;
    overflow: hidden;
  }
  .cat-header::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 4px;
    background: var(--cc);
    border-radius: 4px 0 0 4px;
  }
  .cat-icon { font-size: 1.8rem; }
  .cat-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    color: var(--navy);
    margin: 0;
  }
  .cat-header p { margin: 0.2rem 0 0; color: var(--muted); font-size: 0.85rem; }
  .cat-badge {
    margin-left: auto;
    background: var(--cc);
    color: #fff;
    font-size: 0.82rem;
    font-weight: 700;
    padding: 0.35rem 0.9rem;
    border-radius: 100px;
    white-space: nowrap;
  }

  /* Notes Grid */
  .notes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 0.85rem;
  }

  /* Note Card */
  .note-card {
    display: flex;
    align-items: stretch;
    justify-content: space-between;
    background: var(--surface);
    border: 1.5px solid var(--border);
    border-radius: 12px;
    padding: 1.1rem 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.22s ease;
    position: relative;
    overflow: hidden;
    gap: 0.75rem;
  }
  .note-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 2px;
    background: var(--nc);
    opacity: 0;
    transition: opacity 0.2s;
  }
  .note-card:hover {
    box-shadow: 0 6px 24px rgba(0,0,0,0.09);
    transform: translateY(-2px);
    border-color: color-mix(in srgb, var(--nc) 35%, var(--border));
  }
  .note-card:hover::before { opacity: 1; }
  .note-card-inner { flex: 1; display: flex; flex-direction: column; gap: 0.55rem; min-width: 0; }
  .note-top { display: flex; align-items: center; gap: 0.5rem; }
  .note-cat-dot {
    width: 8px; height: 8px; min-width: 8px;
    border-radius: 50%;
  }
  .note-date { font-size: 0.72rem; color: var(--muted); margin-left: auto; }
  .note-title {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--navy);
    line-height: 1.4;
    margin: 0;
    word-break: break-word;
  }
  .note-tags { display: flex; flex-wrap: wrap; gap: 0.35rem; margin-top: 0.2rem; }
  .note-tag {
    font-size: 0.68rem;
    padding: 0.12rem 0.5rem;
    border-radius: 100px;
    background: var(--bg);
    color: var(--muted);
    border: 1px solid var(--border);
    font-weight: 500;
    line-height: 1.5;
  }
  .note-tag--more { background: color-mix(in srgb, var(--nc) 10%, white); color: var(--nc); border-color: color-mix(in srgb, var(--nc) 25%, var(--border)); }
  .note-arrow {
    display: flex;
    align-items: center;
    color: var(--muted);
    font-size: 1rem;
    transition: transform 0.2s, color 0.2s;
    align-self: center;
    flex-shrink: 0;
  }
  .note-card:hover .note-arrow { transform: translateX(3px); color: var(--nc); }

  /* No results */
  .no-results { text-align: center; padding: 4rem 2rem; color: var(--muted); }
  .no-results-icon { font-size: 3rem; margin-bottom: 1rem; }
  .no-results h3 { font-family: 'Playfair Display', serif; color: var(--navy); font-size: 1.4rem; margin-bottom: 0.5rem; }
  .no-results p { font-size: 0.95rem; margin-bottom: 1.5rem; }
  .reset-btn {
    background: var(--accent);
    color: #fff;
    border: none;
    padding: 0.65rem 1.5rem;
    border-radius: 8px;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .notes-grid { grid-template-columns: 1fr; }
    .hero-stats { flex-direction: row; }
    .search-filter-bar { top: 0; position: inherit; }
    .cat-badge { display: none; }
  }
</style>