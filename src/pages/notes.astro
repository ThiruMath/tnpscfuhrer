<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8"/>
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <meta name="description" content="Browse 389 TNPSC study notes — History, Polity, Economics, Data Science, Maths and more."/>
  <title>Notes Browser | TNPSC Fuhrer</title>
  <link rel="icon" href="https://tnpscfuhrer.in/favicon.svg" type="image/svg+xml"/>
  <link rel="preconnect" href="https://fonts.googleapis.com"/>
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #F8F7F4; --surface: #FFFFFF; --border: #E8E5DF;
      --text: #1C1C1C; --muted: #6B6860; --accent: #C1121F;
      --accent-soft: #FFF0F0; --navy: #14213D;
      --radius: 12px; --shadow: 0 2px 16px rgba(0,0,0,.07);
    }
    *, *:before, *:after { box-sizing: border-box; margin: 0; padding: 0; }
    html { font-size: 16px; scroll-behavior: smooth; }
    body { font-family: 'DM Sans', sans-serif; background: var(--bg); color: var(--text); line-height: 1.6; min-height: 100vh; }
    a { color: inherit; text-decoration: none; }
    h1,h2,h3,h4 { font-family: 'Playfair Display', serif; line-height: 1.2; }

    /* NAV */
    nav { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 2rem; position: sticky; top: 0; z-index: 100; display: flex; align-items: center; justify-content: space-between; height: 64px; }
    .nav-logo { font-family: 'Playfair Display', serif; font-size: 1.3rem; font-weight: 700; color: var(--navy); letter-spacing: -.02em; }
    .nav-logo span { color: var(--accent); }
    .nav-links { display: flex; gap: .25rem; list-style: none; }
    .nav-links a { padding: .5rem .85rem; border-radius: 8px; font-size: .9rem; font-weight: 500; color: var(--muted); transition: all .15s ease; }
    .nav-links a:hover, .nav-links a.active { background: var(--bg); color: var(--text); }

    /* LAYOUT */
    .container { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem; }
    .page-header { padding: 3.5rem 0 2.5rem; border-bottom: 1px solid var(--border); margin-bottom: 2.5rem; }
    .page-header h1 { font-size: clamp(2rem,4vw,2.8rem); color: var(--navy); }
    .page-header p { margin-top: .65rem; color: var(--muted); font-size: 1.05rem; max-width: 560px; }
    .badge { display: inline-flex; align-items: center; gap: .4rem; background: var(--accent-soft); color: var(--accent); padding: .25rem .75rem; border-radius: 100px; font-size: .78rem; font-weight: 600; letter-spacing: .04em; text-transform: uppercase; margin-bottom: 1rem; }

    /* CONTROLS */
    .controls { display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 1rem; margin-bottom: 1.25rem; }
    .view-tabs { display: flex; gap: .4rem; }
    .view-tab { padding: .38rem .85rem; border-radius: 6px; font-size: .82rem; font-weight: 500; border: 1.5px solid var(--border); background: var(--surface); cursor: pointer; font-family: 'DM Sans', sans-serif; color: var(--muted); transition: all .15s; }
    .view-tab.active { background: var(--bg); border-color: var(--navy); color: var(--navy); font-weight: 600; }
    .search-wrap { position: relative; }
    .search-wrap input { width: 300px; padding: .65rem 1rem .65rem 2.6rem; border: 1.5px solid var(--border); border-radius: 8px; font-family: 'DM Sans', sans-serif; font-size: .92rem; background: var(--surface); color: var(--text); outline: none; transition: border-color .15s; }
    .search-wrap input:focus { border-color: var(--accent); }
    .search-wrap svg { position: absolute; left: .8rem; top: 50%; transform: translateY(-50%); color: var(--muted); width:15px; height:15px; pointer-events:none; }

    /* CATEGORY TABS */
    .cat-tabs { display: flex; gap: .5rem; flex-wrap: wrap; margin-bottom: 1.75rem; }
    .cat-tab { padding: .38rem .85rem; border-radius: 100px; border: 1.5px solid var(--border); background: var(--surface); font-size: .82rem; font-weight: 500; color: var(--muted); cursor: pointer; transition: all .15s; font-family: 'DM Sans', sans-serif; }
    .cat-tab:hover { border-color: var(--navy); color: var(--navy); }
    .cat-tab.active { background: var(--navy); color: #fff; border-color: var(--navy); }

    /* TWO-COL LAYOUT */
    .notes-layout { display: grid; grid-template-columns: 290px 1fr; gap: 1.5rem; align-items: start; padding-bottom: 3rem; }
    @media (max-width: 780px) { .notes-layout { grid-template-columns: 1fr; } .search-wrap input { width: 100%; } }

    /* LIST PANEL */
    .notes-list { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; position: sticky; top: 80px; }
    .list-header { padding: .8rem 1rem; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
    .list-header strong { font-size: .92rem; color: var(--navy); font-family: 'Playfair Display', serif; }
    .list-header span { font-size: .78rem; color: var(--muted); }
    .list-scroll { max-height: 580px; overflow-y: auto; }
    .list-scroll::-webkit-scrollbar { width: 4px; }
    .list-scroll::-webkit-scrollbar-thumb { background: var(--border); border-radius: 2px; }
    .note-item { padding: .7rem 1rem; border-bottom: 1px solid var(--border); cursor: pointer; transition: background .1s; display: flex; align-items: center; justify-content: space-between; font-size: .86rem; color: var(--text); }
    .note-item:last-child { border-bottom: none; }
    .note-item:hover { background: var(--bg); }
    .note-item.active { background: var(--accent-soft); color: var(--accent); font-weight: 600; border-left: 3px solid var(--accent); padding-left: calc(1rem - 3px); }
    .note-item .bm-star { font-size: .7rem; flex-shrink: 0; margin-left: .4rem; }
    .no-results { padding: 2rem; text-align: center; color: var(--muted); font-size: .88rem; }

    /* DETAIL PANEL */
    .note-detail { background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius); min-height: 480px; }
    .detail-header { padding: 1.4rem 1.5rem; border-bottom: 1px solid var(--border); display: flex; align-items: flex-start; justify-content: space-between; gap: 1rem; }
    .detail-header h2 { font-size: 1.45rem; color: var(--navy); }
    .detail-header .fname { font-size: .75rem; color: var(--muted); margin-top: .2rem; font-family: monospace; }
    .btn-bm { padding: .38rem .9rem; border-radius: 8px; font-size: .82rem; font-weight: 500; border: 1.5px solid var(--border); background: var(--surface); cursor: pointer; font-family: 'DM Sans', sans-serif; color: var(--muted); transition: all .15s; white-space: nowrap; }
    .btn-bm:hover { border-color: var(--accent); color: var(--accent); }
    .btn-bm.saved { background: var(--accent-soft); color: var(--accent); border-color: var(--accent); }
    .detail-body { padding: 1.5rem; line-height: 1.85; font-size: .93rem; color: var(--text); }
    .detail-body h1 { font-size: 1.35rem; color: var(--navy); margin: 1.2em 0 .5em; }
    .detail-body h2 { font-size: 1.15rem; color: var(--navy); margin: 1em 0 .4em; border-bottom: 1px solid var(--border); padding-bottom: .25em; }
    .detail-body h3 { font-size: 1rem; color: var(--accent); margin: .85em 0 .3em; }
    .detail-body h4 { font-size: .93rem; color: var(--muted); margin: .7em 0 .25em; }
    .detail-body strong { color: var(--navy); }
    .detail-body code { background: #f3f2ef; color: var(--accent); padding: 1px 5px; border-radius: 4px; font-size: .85em; font-family: monospace; }
    .detail-body ul, .detail-body ol { padding-left: 1.4em; margin: .5em 0; }
    .detail-body li { margin: .3em 0; }
    .detail-body p { margin: .55em 0; }

    /* EMPTY STATE */
    .note-empty { display: flex; flex-direction: column; align-items: center; justify-content: center; min-height: 420px; color: var(--muted); gap: .75rem; text-align: center; padding: 2rem; }
    .note-empty .ei { font-size: 2.8rem; }
    .note-empty h3 { font-size: 1.2rem; color: var(--navy); }
    .note-empty p { font-size: .9rem; max-width: 280px; }

    /* SPINNER */
    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner { width: 30px; height: 30px; border: 3px solid var(--border); border-top-color: var(--accent); border-radius: 50%; animation: spin .7s linear infinite; }
    .loading-wrap { display: flex; flex-direction: column; align-items: center; padding: 3.5rem 0; gap: 1rem; }
    .loading-wrap p { color: var(--muted); font-size: .88rem; }

    footer { background: var(--navy); color: #fff9; text-align: center; padding: 2rem; font-size: .85rem; margin-top: 2rem; }
    footer strong { color: #fff; }
  </style>
</head>
<body>

<nav>
  <a href="https://tnpscfuhrer.in/" class="nav-logo">TNPSC <span>Fuhrer</span></a>
  <ul class="nav-links">
