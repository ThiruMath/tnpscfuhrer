<main>
  <div class="container">
    <div class="page-header">
      <span class="badge">389 Study Notes</span>
      <h1>Notes Browser</h1>
      <p>Exam-focused notes covering Polity, History, Economics, Data Science, Maths and more — all in one place.</p>
    </div>

    <div class="controls">
      <div class="view-tabs">
        <button class="view-tab active" onclick="switchView('browse',this)">🗂 Browse</button>
        <button class="view-tab" onclick="switchView('recent',this)">🕐 Recent</button>
        <button class="view-tab" onclick="switchView('bookmarks',this)">⭐ Saved</button>
      </div>
      <div class="search-wrap">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
        <input type="text" id="searchInput" placeholder="Search notes..." oninput="renderList()"/>
      </div>
    </div>

    <div class="cat-tabs" id="catTabs">
      <button class="cat-tab active" onclick="switchCat('All Notes',this)">📚 All (389)</button>
      <button class="cat-tab" onclick="switchCat('Tamil & History',this)">🏛 Tamil & History</button>
      <button class="cat-tab" onclick="switchCat('Polity & Governance',this)">⚖️ Polity</button>
      <button class="cat-tab" onclick="switchCat('Economics & Banking',this)">💰 Economics</button>
      <button class="cat-tab" onclick="switchCat('Data Science & AI',this)">🤖 Data Science</button>
      <button class="cat-tab" onclick="switchCat('Mathematics',this)">📐 Maths</button>
      <button class="cat-tab" onclick="switchCat('Cybersecurity',this)">🔐 Cyber</button>
      <button class="cat-tab" onclick="switchCat('Current Affairs',this)">📰 Current Affairs</button>
    </div>

    <div class="notes-layout">
      <!-- LIST -->
      <div class="notes-list">
        <div class="list-header">
          <strong id="listTitle">All Notes</strong>
          <span id="listCount">389 notes</span>
        </div>
        <div class="list-scroll" id="notesList"></div>
      </div>

      <!-- DETAIL -->
      <div class="note-detail" id="noteDetail">
        <div class="note-empty">
          <div class="ei">📖</div>
          <h3>Select a Note</h3>
          <p>Click any note from the list to load its study content.</p>
        </div>
      </div>
    </div>
  </div>
</main>

<footer>
  <p>Built for TNPSC aspirants — <strong>TNPSC Fuhrer</strong> © 2026</p>
</footer>

<script>
const ALL_FILES = ["10th_Tamil","11th_Five_Year_Plan","12_Volume","1936","19th_Century_Reforms","20th_Century_Authors","42nd_Ammendment","6th_Tamil","7th_Tamil","8th_Tamil","9th_Tamil","ADMINISTRATIVE__REFORMS___TRIBUNALS","AI","AI_Blog_Post_Generator","AP","ASCII","AUC","Accuracy","Accuracy__recall__precision","Adam_Smith","Addition_Properties","Administration_of_States_with_reference_to_Tamil_Nadu__30_Questions_","Administrative_Machinery_in_India","Advent_of_Europeans","Adversarial_artificial_intelligence","Age_composition","Airways","Alexander_Cunningham","Algorithms","Alternative_Growth_Indicators","Amendment_Process_and_Procedure","Ancient_History","Ancient_Tamil_Society","Annual_Plan_1990_-_91___92","Antivirus_software","Appointment","April","April_CA","Area___Volume","Areas_Related_to_Circles","Article_120","Article_2","Article_315","Article_316","Article_317","Articles_Related_to_Public_Service_Commissions","Artificial_neural_network","Artificial_neural_network_2","Awards","Bad_Loan","Bank_Money_or_Deposit_Money","Banking","Banking_Sector_Reforms","Banking_structure_in_India","Barter_System","Basic_Concepts_and_Measures","Basic_geometrical_ideas__2_-D_","Baye_s_Theorem","Bayes_Theorem","Beautiful_soup","Big_Data","Binning","Binomial_Theorem","Bodies_Associated_with_Planning_in_India","Books","Booting","Brahmo_Samaj","Budget","CA___GS","COMMISSION","CPU","C__Natesa_Mudaliar","Cabinet_Secretariat","Capitalism","Carl_Fredrich_Gauss","Cashless_Economy","Categorical_data","Causes_of_Inflation","Central_Bank_Digital_Currency","Central_Govt","Central_Planning","Central_Secretariat","Cheet_Sheet","Chief_Minister","Child_Labour","Circle","Citizenship","Class_6","Classification_of_Banks","Classification_of_Taxes","Clipping","Cloud_Computing","Co-operative_Bank","Coefficient_of_Variation","Coins___Notes","Committee","Communication","Complex_Sentence","Components_of_a_Budget","Concepts_and_Terms_Related_to_Inflation","Confusion_matrix","Constitution_of_India","Contribution_of_Tamilians_in_Freedom_movement","Coordinate_Geometry","Countable_and_Uncountable_sets","Cryptocurrency","Cryptographic_Attack","Curzon","DBSCAN","Daily_News","Data","Data_Analytics","Data_Pre_Processing","Data_Representations","Data_Science","Data_Science_Infosys","Data_Science_do","Data_Scientist","Data_Types","Debendranath_Tagore","Decentralised_planning","Decision_Tree_Regression","Decision_Trees","Deep_Learning","Deep_learning_and_machine_learning","Demand_and_Supply_-_Money","Developement_Banks","Development_of_Rationalism","Difference_between_Ordinary_Bill_and_Money_Bill","Difficulties_and_Problems_in_Calculation","Directive_Principles_of_State_Policy","Discrete_Probability","District_Administration","Downsampling_and_Upweighting","E-Governance","EMERGENCY","EMPOWERMENT_OF_WOMEN","ENIAC","Economic_Development","Economic_Growth","Economic_Reforms","Economice_Basics","Economics","Economics_CA","Effects_of_Inflation","Eighth_Five_Year_Plan_1992_-_97","Electronic_Health_Records","Electronic_orders_and_digital_payments","Elementary_Set_Theory","Eleventh_Five_Year_Plan_2007_-_12","Embedding_Vectors","Encoding","Ethical_principles_and_methodologies","Event","Excel_Shortcuts","Excutive_-_State","Executive","Executive_-_Union","Executive_1","Fall_of_the_Soviet_Union_and_Economic_Liberalisation__1991-present_","False_positive_rate","Famous_people","Father_of_Computer","Feature_Crosses","Feature_Engineering","Feature_Scaling","Feb","Feb_CA","Feedback_Loop","Fifth_Five_Year_Plan_1974_-_79","File_Types","Finance_Commission","Financial_position_of_a_Bank","First_Five_Year_Plan_1951-56","Fiscal_Policy_and_Monetary_Policy","Five-Year_Plans","Five_Year_Plan_Model___Assessment","Forth_Five_Year_Plan_1969_-_74","Fractions","Free_Cybersecurity_Services_and_Tools","Functions_of_Banks","Functions_of_Money","Fundamental_Duties","Fundamental_Rights","G2","G2A_Mains","GMM","GS","GST","Ganga_Water_Treaty","General_Awareness","General_Science","General_Tamil","Generalization","Generation","Generative_AI","Geography","Globalization","Glossary_Python","Glossary_Python_Basics","Glossary_of_Cyber_Security","Gottfried_Wilhelm_Leibniz","Governor","Gradient_Boosting","Gradient_Boosting_Regression","Gradient_descent","Group_2A_Syllabus","Group_2___2A_Prelims","HCF_-_LCM","HCF___LCM","HCF___LCM_1","Hadoop","Handling_the_missing_values","Henri_Poincare","Hierarchical_Clustering","Hilton_Young_Commission","History","History_of_TN","History_of_artificial_intelligence-","History_on_Polity","Hyperparameter","IBM","INC","INC_Sessions","INM","ISRO","ISRO_2","Imbalanced_Datasets","Import_Required_Libraries","Income_Classification","Income_Theory","Independent_Events","Indian_Government_Structure","Indirect_taxes_in_India","Inflation","International","Intrusion_detection_system","Irrational_Numbers","Ishwar_Chandra_Vidyasagar","J_P__Morgan","James_Prinsep","Jan","Jan_14","Jan_CA","Jawaharlal_Nehru","Join_Siting","Judgements","Jupyter","Justice_Party","Justice_magazine","K-Means","Keras","Keshab_Chandra_Sen","Knowing_our_Numbers","LDA","LaTeX","LaTeX_1","Labels","Land_Reforms_and_Agriculture","Lasso_Regression","Law_Making_Process","Liberalisation","Linear_Regression","Linear_scaling","Lines_and_Angles","Literacy_Rate","Local_Self-Government","Location","Log_scaling","Logistic_Regression","Lok_Adalat","Lok_Ayukta","Lord_Curzon","Loss","MGR","MNA","Machine_Learning","Making_of_Indian_Constitution","Making_of_constitution","Malware","March","Marriage_Age_Committee","Math","Math_Syllabus","Mathematicians","Mathi","Matplotlib","Mean","Mean_deviation","Measurers_of_Inflation","Measurers_to_Control_Inflation","Measures_of_Central_Tendency","Measures_of_Dispersion","Median","Medical_Services_Recruitment_Board_Composition","Mensuration","Merger_of_public_sector_bank_in_India","Metallic_Standard","Methods_of_Measurement","Methods_of_collecting_primary_data","Metric_Spaces","Microprocessor","Mode","Model","Model_complexity","Modern_History_of_Tamil_Nadu__Tamil_Society_