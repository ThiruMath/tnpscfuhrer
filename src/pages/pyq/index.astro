---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="TNPSC Previous Year Questions | TNPSC Fuhrer" description="Practice TNPSC Group 2A and Group 4 previous year questions." active="PYQ Quiz">
  <main class="pyq-list-wrap">
    <div class="container">
      <div class="header-section">
        <h1 class="page-title">PYQ Practice Zone</h1>
        <p class="page-desc">Test your preparation with actual Previous Year Questions from TNPSC exams.</p>
      </div>

      <div class="pyq-grid">
        <!-- Group 4 2025 -->
        <a href="/pyq/tnpsc-2025-GRP4" class="pyq-card g4-card">
          <div class="card-icon">📝</div>
          <div class="card-content">
            <span class="card-tag">NEW</span>
            <h2 class="card-title">TNPSC Group 4 Comprehensive Exam</h2>
            <p class="card-meta">2025 • Tamil & General Studies</p>
            <span class="btn-start">Start Quiz →</span>
          </div>
        </a>

        <!-- Group 2A 2026 -->
        <a href="/pyq/tnpsc-2026-GRP2A" class="pyq-card g2-card">
          <div class="card-icon">📋</div>
          <div class="card-content">
            <h2 class="card-title">TNPSC Group 2A</h2>
            <p class="card-meta">2026 • Paper II — General Studies</p>
            <span class="btn-start">Start Quiz →</span>
          </div>
        </a>
      </div>
    </div>
  </main>
</Layout>

<style>
  .pyq-list-wrap {
    min-height: calc(100vh - 64px);
    background: #f8f9fa;
    padding: 4rem 0;
    font-family: 'Google Sans', 'DM Sans', sans-serif;
  }
  
  .container {
    max-width: 900px;
    margin: 0 auto;
    padding: 0 1rem;
  }

  .header-section {
    text-align: center;
    margin-bottom: 3rem;
  }

  .page-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #202124;
    margin-bottom: 0.5rem;
    font-family: 'Playfair Display', serif;
  }

  .page-desc {
    font-size: 1.1rem;
    color: #5f6368;
  }

  .pyq-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .pyq-card {
    display: flex;
    flex-direction: column;
    background: #fff;
    border-radius: 16px;
    padding: 2rem;
    text-decoration: none;
    color: inherit;
    border: 1px solid #e0e0e0;
    transition: all 0.2s ease;
    position: relative;
    overflow: hidden;
  }

  .pyq-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.08);
    border-color: transparent;
  }

  .g4-card { border-top: 4px solid #1a73e8; }
  .g2-card { border-top: 4px solid #e37400; }

  .card-icon {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .card-tag {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    background: #1a73e8;
    color: #fff;
    font-size: 0.7rem;
    font-weight: 800;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
  }

  .card-title {
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    color: #202124;
  }

  .card-meta {
    font-size: 0.9rem;
    color: #5f6368;
    margin-bottom: 1.5rem;
  }

  .btn-start {
    display: inline-block;
    margin-top: auto;
    font-weight: 600;
    color: #1a73e8;
  }
  
  .pyq-card:hover .btn-start {
    text-decoration: underline;
  }
</style>
